---
interface Props {
  before: string;
  after: string;
}

const { before, after } = Astro.props;

const detectedItems = [
  { label: 'Prénom', original: 'Jean', masked: '[Prénom]', type: 'ID' },
  { label: 'Nom', original: 'Dupont', masked: '[Nom]', type: 'ID' },
  { label: 'Email', original: 'jean.dupont@acme.com', masked: '[Email]', type: '@' },
  { label: 'SIRET', original: '123 456 789 00012', masked: '[SIRET]', type: '#' },
];
---

<div class="hero-card" data-hero-demo data-before={before} data-after={after}>
  <div class="scan-line" aria-hidden="true"></div>

  <div class="status-row">
    <div class="status-indicator exposed" data-status-indicator>
      <span class="status-dot"></span>
      <span class="status-text" data-status-text>EXPOSÉ</span>
    </div>
    <div class="terminal-label">
      <span class="terminal-path">~/paranoia</span>
      <span class="terminal-cursor">▊</span>
    </div>
  </div>

  <div class="card accent" data-demo-card>
    <div class="tag-row">
      <span class="tag" data-demo-tag>Prompt brut</span>
      <span class="processing-badge" data-processing hidden>Analyse en cours...</span>
    </div>

    <div class="demo-text" aria-live="polite">
      <pre class="demo-code" data-demo-text>{before}</pre>
    </div>

    <div class="chips" aria-hidden="true">
      {detectedItems.map((item) => (
        <span class="chip exposed" data-chip data-original={item.original} data-masked={item.masked}>
          <span class="chip-icon">{item.type}</span>
          <span class="chip-value">{item.original}</span>
        </span>
      ))}
    </div>
  </div>

  <div class="demo-controls">
    <button class="btn secondary" type="button" data-demo-toggle>
      <span class="btn-icon">[ ]</span>
      Voir la version protégée
    </button>

    <div class="demo-progress" aria-label="Progression avant bascule">
      <div class="demo-progress__bar"></div>
    </div>

    <span class="muted mini">
      <span class="shield-icon">SEC</span>
      L'utilisateur relit la version masquée avant l'envoi.
    </span>
  </div>

  <div class="demo-metrics">
    <div class="metric">
      <div class="metric-value"><span class="metric-number">4</span></div>
      <div class="metric-label">Exemples détectés</div>
    </div>
    <div class="metric">
      <div class="metric-value"><span class="metric-number">Local</span></div>
      <div class="metric-label">Analyse côté poste</div>
    </div>
    <div class="metric">
      <div class="metric-value"><span class="metric-number">Review</span></div>
      <div class="metric-label">Relu avant départ</div>
    </div>
  </div>

  <div class="list">
    <div class="pill"><span class="pill-dot"></span>Détection PII</div>
    <div class="pill"><span class="pill-dot"></span>Masquage</div>
    <div class="pill"><span class="pill-dot"></span>Politique d'équipe</div>
  </div>
</div>

<script>
  const demo = document.querySelector('[data-hero-demo]');

  if (demo instanceof HTMLElement) {
    const before = demo.dataset.before || '';
    const after = demo.dataset.after || '';
    const text = demo.querySelector('[data-demo-text]');
    const toggle = demo.querySelector('[data-demo-toggle]');
    const tag = demo.querySelector('[data-demo-tag]');
    const status = demo.querySelector('[data-status-indicator]');
    const statusText = demo.querySelector('[data-status-text]');
    const card = demo.querySelector('[data-demo-card]');
    const processing = demo.querySelector('[data-processing]');
    const chips = Array.from(demo.querySelectorAll('[data-chip]'));
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let protectedView = false;
    let busy = false;

    const render = () => {
      if (text) text.textContent = protectedView ? after : before;
      if (tag) tag.textContent = protectedView ? 'Version relue' : 'Prompt brut';
      if (status) {
        status.classList.toggle('protected', protectedView);
        status.classList.toggle('exposed', !protectedView);
      }
      if (statusText) statusText.textContent = protectedView ? 'PROTÉGÉ' : 'EXPOSÉ';
      if (toggle) {
        toggle.textContent = protectedView ? "Voir l'original" : 'Voir la version protégée';
      }

      chips.forEach((chip) => {
        const value = chip.querySelector('.chip-value');
        chip.classList.toggle('masked', protectedView);
        chip.classList.toggle('exposed', !protectedView);
        chip.classList.add('pulsing');
        if (value) value.textContent = protectedView ? chip.dataset.masked || '' : chip.dataset.original || '';
        window.setTimeout(() => chip.classList.remove('pulsing'), 450);
      });
    };

    const flip = () => {
      if (busy) return;
      busy = true;
      demo.classList.add('scanning');
      card?.classList.add('processing');
      if (processing instanceof HTMLElement) processing.hidden = false;

      window.setTimeout(() => {
        protectedView = !protectedView;
        render();
        demo.classList.remove('scanning');
        card?.classList.remove('processing');
        if (processing instanceof HTMLElement) processing.hidden = true;
        busy = false;
      }, reduceMotion ? 20 : 700);
    };

    toggle?.addEventListener('click', flip);
    if (!reduceMotion) window.setInterval(flip, 6500);
  }
</script>
