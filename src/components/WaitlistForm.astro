<form class="waitlist-form" data-waitlist-form action="/api/waitlist" method="post" aria-describedby="waitlist-hint waitlist-status">
  <div class="waitlist-field">
    <label for="waitlist-email" class="sr-only">Email professionnel</label>
    <input
      id="waitlist-email"
      type="email"
      name="email"
      placeholder="email@entreprise.com"
      autocomplete="email"
      inputmode="email"
      required
    />
  </div>
  <label class="sr-only" aria-hidden="true" for="waitlist-website">Site web</label>
  <input
    id="waitlist-website"
    class="sr-only"
    type="text"
    name="website"
    autocomplete="off"
    tabindex="-1"
    aria-hidden="true"
  />
  <button class="xo-button xo-button--primary" type="submit" data-submit-label>Rejoindre la beta</button>
</form>
<p class="waitlist-hint" id="waitlist-hint">
  Votre email est transmis à l'équipe Paranoia. Réponse sous 48h.
</p>
<div id="waitlist-status" aria-live="polite"></div>

<script>
  const form = document.querySelector('[data-waitlist-form]');
  const status = document.querySelector('#waitlist-status');
  const submit = document.querySelector('[data-submit-label]');
  const input = document.querySelector('#waitlist-email');
  const honeypot = document.querySelector('#waitlist-website');

  const setStatus = (message, type) => {
    if (!status) return;
    status.innerHTML = message ? `<div class="waitlist-status-message waitlist-status-message--${type}">${message}</div>` : '';
  };

  const setFormState = (state) => {
    if (form instanceof HTMLFormElement) {
      form.dataset.state = state;
    }
  };

  if (form instanceof HTMLFormElement && input instanceof HTMLInputElement) {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      setStatus('', '');
      setFormState('idle');

      const email = input.value.trim();
      if (!/\S+@\S+\.\S+/.test(email)) {
        setStatus('Ajoute un email professionnel valide.', 'error');
        setFormState('error');
        input.setAttribute('aria-invalid', 'true');
        return;
      }

      input.removeAttribute('aria-invalid');
      if (submit instanceof HTMLButtonElement) {
        submit.disabled = true;
        submit.textContent = 'Envoi...';
      }
      setFormState('loading');

      try {
        const response = await fetch('/api/waitlist', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email,
            website: honeypot instanceof HTMLInputElement ? honeypot.value : '',
          }),
        });
        const payload = await response.json().catch(() => ({}));

        if (!response.ok) {
          window.dispatchEvent(new CustomEvent('site:event', {
            detail: {
              name: 'waitlist_submit_error',
              props: { status: response.status },
            },
          }));
          setStatus(payload.error || "Impossible d'enregistrer cet email pour le moment.", 'error');
          setFormState('error');
          return;
        }

        input.value = '';
        window.dispatchEvent(new CustomEvent('site:event', {
          detail: {
            name: 'waitlist_submit_success',
            props: { status: response.status },
          },
        }));
        setStatus('Merci ! On revient vers toi très vite.', 'success');
        setFormState('success');
      } catch (error) {
        console.error(error);
        window.dispatchEvent(new CustomEvent('site:event', {
          detail: {
            name: 'waitlist_submit_error',
            props: { status: 'network' },
          },
        }));
        setStatus("Impossible d'enregistrer cet email pour le moment.", 'error');
        setFormState('error');
      } finally {
        if (submit instanceof HTMLButtonElement) {
          submit.disabled = false;
          submit.textContent = 'Rejoindre la beta';
        }
        if (form.dataset.state === 'loading') {
          setFormState('idle');
        }
      }
    });
  }
</script>
