---
// Bulles de chat qui défilent en boucle — mesuré sur x.ai 2026-06-23.
// Usage: <ChatBubbleDemo messages={messages} />

interface ChatMessage {
  role: 'user' | 'assistant';
  text: string;
}

interface Props {
  messages?: ChatMessage[];
  /** Tuile hero : contenu décoratif dans un lien parent (aria-hidden). */
  decorative?: boolean;
  class?: string;
}

const {
  decorative = false,
  messages = [
    { role: 'user', text: 'How do black holes form?' },
    { role: 'assistant', text: 'A massive star exhausts its fuel and gravity collapses the core into a singularity.' },
    { role: 'user', text: 'What causes aurora borealis?' },
    { role: 'assistant', text: 'Solar particles hit atmospheric gases near the poles, exciting them to glow.' },
    { role: 'user', text: 'Explain quantum entanglement simply' },
    { role: 'assistant', text: 'Two particles share a state — measuring one instantly determines the other, regardless of distance.' },
  ],
  class: className = '',
} = Astro.props;

const messagesJson = JSON.stringify(messages);
---

<div class:list={['xo-chat-demo', className]} aria-hidden={decorative ? 'true' : undefined} data-chat-demo data-messages={messagesJson}>
  {messages.map((msg, i) => (
    <div
      class={`xo-chat-bubble ${msg.role === 'assistant' ? 'is-assistant' : 'is-user'}`}
      data-chat-bubble={i}
    >
      {msg.text}
    </div>
  ))}
</div>

<script>
  import { CHAT_DEMO_TIMING } from '../../lib/ecosystem-motion.mjs';

  const { STEP, HOLD, FADE, PAUSE } = CHAT_DEMO_TIMING;

  function initChatDemos() {
    const demos = document.querySelectorAll<HTMLElement>('[data-chat-demo]');
    demos.forEach((demo) => {
      if (demo.dataset.initialized) return;
      demo.dataset.initialized = 'true';

      const bubbles = demo.querySelectorAll<HTMLElement>('[data-chat-bubble]');

      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduced) {
        // Tout afficher d'emblée, aucune boucle.
        bubbles.forEach((b) => b.classList.add('is-visible'));
        return;
      }

      // UN SEUL timer actif à la fois : chaque étape planifie exactement la suivante,
      // et start()/stop() nettoient avant de (re)lancer → pas d'empilement de setTimeout.
      let timer: ReturnType<typeof setTimeout> | null = null;

      function clearTimer() {
        if (timer !== null) {
          clearTimeout(timer);
          timer = null;
        }
      }

      function hideAll() {
        // Retire is-visible → fondu de sortie via la transition CSS existante.
        bubbles.forEach((b) => b.classList.remove('is-visible'));
      }

      // Révélation progressive DANS L'ORDRE ; les bulles restent (le conteneur est ancré
      // en bas et clippe le haut quand ça déborde → effet "conversation en cours").
      function revealFrom(i: number) {
        if (i >= bubbles.length) {
          // Dernière bulle atteinte : maintien, puis sortie.
          timer = setTimeout(exit, HOLD);
          return;
        }
        bubbles[i].classList.add('is-visible');
        timer = setTimeout(() => revealFrom(i + 1), STEP);
      }

      function exit() {
        hideAll();
        // Laisse le fondu se jouer + courte pause, puis rejoue depuis la première.
        timer = setTimeout(() => revealFrom(0), FADE + PAUSE);
      }

      function start() {
        clearTimer();
        hideAll();
        revealFrom(0);
      }

      function stop() {
        clearTimer();
      }

      // Boucle TANT QUE visible ; pause hors écran, reprise (depuis le début) à l'entrée.
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) start();
            else stop();
          });
        },
        { threshold: 0.15 }
      );
      observer.observe(demo);
    });
  }

  initChatDemos();
  document.addEventListener('astro:after-swap', initChatDemos);
</script>