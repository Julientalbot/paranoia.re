---
// Métriques de preuve — grands chiffres, petits labels (x.ai/api developer section).
// Usage: <MetricStrip metrics={[{ value: '1M+', label: 'API calls per day' }]} />

interface Metric {
  value: string;
  label: string;
  href?: string;
}

interface Props {
  metrics: Metric[];
  class?: string;
}

const { metrics, class: className = '' } = Astro.props;
---

<div class={`xo-metric-strip ${className}`}>
  {metrics.map((metric) => (
    metric.href ? (
      <a class="xo-metric" href={metric.href}>
        <strong>{metric.value}</strong>
        <span>{metric.label}</span>
      </a>
    ) : (
      <div class="xo-metric">
        <strong>{metric.value}</strong>
        <span>{metric.label}</span>
      </div>
    )
  ))}
</div>