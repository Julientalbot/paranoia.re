---
// Titre hero x.ai : révélation mot à mot au load + (optionnel) dernier mot qui cycle
// (mesuré 2026-06-23 — chaque mot wrappé en inline-block, stagger opacity/translateY).
// Usage:
//   <HeroHeadline id="home-title" class="xo-title--wide" text="Ce que l’IA change dans le travail" />
//   <HeroHeadline text="Frontier AI models for everything you" rotate={['raisonne','décide','agit']} />

interface Props {
  text: string;
  rotate?: string[];
  underline?: string;
  id?: string;
  class?: string;
}

const { text, rotate, underline, id, class: className = '' } = Astro.props;
const words = text.trim().split(/\s+/);
const hasRotate = Array.isArray(rotate) && rotate.length > 0;
const hasUnderline = typeof underline === 'string' && underline.length > 0;
---

<h1 id={id} class:list={['xo-title', 'xo-hl', className]} data-hl>
  {words.map((w, i) => (
    <span class="xo-hl-word" style={`--i:${i}`}>{w}&nbsp;</span>
  ))}
  {hasUnderline && (
    <span class="xo-hl-word xo-hl-underline" style={`--i:${words.length}`}>{underline}</span>
  )}
  {hasRotate && (
    <span class="xo-hl-rotate" style={`--i:${words.length}`} data-hl-rotate>
      {rotate!.map((w, i) => (
        <span class:list={['xo-hl-rotate-word', i === 0 && 'is-active']}>
          {[...w].map((ch, j) => (
            <span class="xo-hl-letter" style={`--j:${j}`}>{ch === ' ' ? ' ' : ch}</span>
          ))}
        </span>
      ))}
    </span>
  )}
</h1>

{hasRotate && (
  <script>
    import { applyHlRotateTick } from '../../lib/ecosystem-motion.mjs';

    function initHlRotate() {
      document.querySelectorAll('[data-hl-rotate]').forEach((el) => {
        if (el.dataset.hlInit) return;
        el.dataset.hlInit = '1';
        const words = [...el.querySelectorAll('.xo-hl-rotate-word')];
        if (words.length < 2) return;
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        let i = 0;
        window.setInterval(() => {
          i = applyHlRotateTick(words, i);
        }, 2400);
      });
    }
    initHlRotate();
    document.addEventListener('astro:after-swap', initHlRotate);
  </script>
)}
