---
// Grille parcourue par des impulsions lumineuses — mesuré sur x.ai 2026-06-23.
// Usage: <GridShimmer /> ou <GridShimmer lines={customLines} opacity={0.4} />

interface ShimmerLine {
  top: string;
  color?: string;
  color2?: string;
  duration?: string;
  delay?: string;
}

interface Props {
  lines?: ShimmerLine[];
  count?: number;
  opacity?: number;
  class?: string;
  style?: string;
}

const palette: [string, string][] = [
  ['#7547d1', '#d147d1'],
  ['#cad147', '#6ed147'],
  ['#478fd1', '#5b47d1'],
  ['#d14783', '#d16847'],
];

const defaultLines: ShimmerLine[] = [
  { top: '20%', color: '#7547d1', color2: '#d147d1', duration: '2.58s', delay: '2.82s' },
  { top: '35%', color: '#cad147', color2: '#6ed147', duration: '2.06s', delay: '3.85s' },
  { top: '55%', color: '#478fd1', color2: '#5b47d1', duration: '2.21s', delay: '0.77s' },
  { top: '70%', color: '#d14783', color2: '#d16847', duration: '1.86s', delay: '4.92s' },
];

const {
  lines,
  count,
  opacity = 0.4,
  class: className = '',
  style = '',
} = Astro.props;

// Bande grille "vivante" façon x.ai : N stries aux cadences/délais désynchronisés
// (déterministe — pas de Math.random, build reproductible). Mesuré : dur 1.8–2.96s, delay 0–5.8s.
const generatedLines: ShimmerLine[] = count
  ? Array.from({ length: count }, (_, i) => {
      const pair = palette[i % palette.length];
      return {
        top: (((i + 0.5) / count) * 100).toFixed(1) + '%',
        color: pair[0],
        color2: pair[1],
        duration: (1.8 + ((i * 29) % 12) / 10).toFixed(2) + 's',
        delay: (((i * 47) % 58) / 10).toFixed(2) + 's',
      };
    })
  : [];

const renderedLines = lines ?? (count ? generatedLines : defaultLines);
---

<div
  class:list={['xo-grid-shimmer', className]}
  aria-hidden="true"
  style={`opacity: ${opacity};${style}`}
>
  {renderedLines.map((line) => (
    <div
      class="xo-grid-shimmer-line"
      style={[
        line.top ? `top: ${line.top};` : '',
        line.color ? `--xo-shimmer-color: ${line.color};` : '',
        line.color2 ? `--xo-shimmer-color-2: ${line.color2};` : '',
        line.duration ? `--xo-shimmer-duration: ${line.duration};` : '',
        line.delay ? `--xo-shimmer-delay: ${line.delay};` : '',
      ].join(' ')}
    />
  ))}
</div>