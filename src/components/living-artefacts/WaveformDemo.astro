---
// Waveform / égaliseur — modalité "Voice" du plateau hero x.ai (mesuré 2026-06-23).
// CSS-driven : N barres animées en hauteur (scaleY 0.4↔1), décalées → onde vivante.
// Usage: <WaveformDemo /> ou <WaveformDemo bars={40} />

import { waveformBarAt } from '../../lib/ecosystem-motion.mjs';

interface Props {
  bars?: number;
  class?: string;
}

const { bars = 36, class: className = '' } = Astro.props;

const items = Array.from({ length: bars }, (_, i) => waveformBarAt(i, bars));
---

<div class:list={['xo-waveform', className]} aria-hidden="true">
  {items.map((b) => (
    <span
      class="xo-waveform-bar"
      style={`height:${b.h}%;--hue:${b.hue};animation-duration:${b.dur}s;animation-delay:${b.delay}s;`}
    ></span>
  ))}
</div>
