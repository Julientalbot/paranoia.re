<form class="pilot-form" data-pilot-form action="/api/pilot" method="post" aria-describedby="pilot-hint pilot-status">
  <div class="pilot-field">
    <label for="pilot-email" class="sr-only">Email professionnel</label>
    <input
      id="pilot-email"
      type="email"
      name="email"
      placeholder="email@entreprise.com"
      autocomplete="email"
      inputmode="email"
      required
    />
  </div>
  <label class="sr-only" aria-hidden="true" for="pilot-website">Site web</label>
  <input
    id="pilot-website"
    class="sr-only"
    type="text"
    name="website"
    hidden
    autocomplete="off"
    tabindex="-1"
    aria-hidden="true"
  />
  <button class="xo-button xo-button--primary" type="submit" data-submit-label>Décrire un pilote</button>
</form>
<p class="pilot-hint" id="pilot-hint">
  Votre email est transmis à l'équipe Paranoia. Réponse sous 48h.
</p>
<div id="pilot-status" aria-live="polite"></div>

<script>
  const form = document.querySelector('[data-pilot-form]');
  const status = document.querySelector('#pilot-status');
  const submit = document.querySelector('[data-submit-label]');
  const input = document.querySelector('#pilot-email');
  const honeypot = document.querySelector('#pilot-website');

  const setStatus = (message, type) => {
    if (!status) return;
    status.innerHTML = message ? `<div class="pilot-status-message pilot-status-message--${type}">${message}</div>` : '';
  };

  const setFormState = (state) => {
    if (form instanceof HTMLFormElement) {
      form.dataset.state = state;
    }
  };

  if (form instanceof HTMLFormElement && input instanceof HTMLInputElement) {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      setStatus('', '');
      setFormState('idle');

      input.removeAttribute('aria-invalid');

      const email = input.value.trim();
      if (!/\S+@\S+\.\S+/.test(email)) {
        setStatus('Indiquez un email professionnel valide.', 'error');
        setFormState('error');
        input.setAttribute('aria-invalid', 'true');
        return;
      }

      if (submit instanceof HTMLButtonElement) {
        submit.disabled = true;
        submit.textContent = 'Envoi...';
      }
      setFormState('loading');

      try {
        const response = await fetch('/api/pilot', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email,
            website: honeypot instanceof HTMLInputElement ? honeypot.value : '',
          }),
        });
        const payload = await response.json().catch(() => ({}));

        if (!response.ok) {
          window.dispatchEvent(new CustomEvent('site:event', {
            detail: {
              name: 'pilot_submit_error',
              props: { status: response.status },
            },
          }));
          setStatus(payload.error || "Impossible d'enregistrer cet email pour le moment.", 'error');
          setFormState('error');
          input.setAttribute('aria-invalid', 'true');
          return;
        }

        input.value = '';
        window.dispatchEvent(new CustomEvent('site:event', {
          detail: {
            name: 'pilot_submit_success',
            props: { status: response.status },
          },
        }));
        setStatus('Merci. Nous revenons vers vous très vite.', 'success');
        setFormState('success');
      } catch (error) {
        console.error(error);
        window.dispatchEvent(new CustomEvent('site:event', {
          detail: {
            name: 'pilot_submit_error',
            props: { status: 'network' },
          },
        }));
        setStatus("Impossible d'enregistrer cet email pour le moment.", 'error');
        setFormState('error');
        input.setAttribute('aria-invalid', 'true');
      } finally {
        if (submit instanceof HTMLButtonElement) {
          submit.disabled = false;
          submit.textContent = 'Décrire un pilote';
        }
        if (form.dataset.state === 'loading') {
          setFormState('idle');
        }
      }
    });
  }
</script>
