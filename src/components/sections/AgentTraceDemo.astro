---
// AgentTraceDemo.astro — Terminal vivant qui montre un agent qui travaille.
// Mesuré sur x.ai 2026-06-23 : progress bar, étapes séquentielles, progressive blur.
// Usage: <AgentTraceDemo title="hermes/case-0012" steps={traceSteps} />

interface TraceStep {
  prompt?: string;      // symbole en début de ligne (▸, ◆, ❯)
  text: string;         // contenu de la ligne
  accent?: boolean;     // surligné en couleur accent
  dim?: boolean;        // texte grisé
  progress?: number;    // 0-100, met à jour la progress bar
}

interface Props {
  title?: string;
  steps?: TraceStep[];
  progressLabel?: string;
  class?: string;
}

const {
  title = 'projects/main',
  steps = [
    { prompt: '❯', text: 'Add rate limiting to all API routes.', dim: true },
    { text: 'Thinking...', dim: true },
    { prompt: '▸', text: 'grep "rateLimit" src/', dim: true },
    { prompt: '▸', text: 'read_file src/api/routes.ts (42 lines)', dim: true },
    { text: 'Scan route handlers', accent: true, progress: 16 },
    { prompt: '◆', text: 'Thought for 2.8s', dim: true },
    { prompt: '◆', text: 'Edit src/api/routes.ts', accent: true, progress: 32 },
    { text: 'export async function handler(req) {', dim: true },
    { text: '  await rateLimit(req, { max: 100 });', dim: true },
    { prompt: '✓', text: 'Done. 3 routes patched.', accent: true, progress: 100 },
  ],
  progressLabel = '16.15%',
  class: className = '',
} = Astro.props;

const stepJson = JSON.stringify(steps);
---

<div class={`xo-trace-demo ${className}`} data-trace-demo data-steps={stepJson} data-progress-label={progressLabel}>
  <div class="xo-trace-demo-header">
    <div class="xo-trace-demo-dots" aria-hidden="true">
      <span></span><span></span><span></span>
    </div>
    <div class="xo-trace-demo-title">{title}</div>
    <div class="xo-trace-demo-progress">
      <span class="xo-trace-demo-bar"><span class="xo-trace-demo-bar-fill" data-trace-bar></span></span>
      <span data-trace-progress-text>{progressLabel}</span>
    </div>
  </div>
  <div class="xo-trace-demo-body" data-trace-body>
    {steps.map((step, i) => (
      <div class="xo-trace-demo-line" data-trace-line={i}>
        {step.prompt && <span class="xo-trace-demo-prompt">{step.prompt}</span>}
        <span class={step.accent ? 'xo-trace-demo-accent' : step.dim ? 'xo-trace-demo-dim' : ''}>{step.text}</span>
      </div>
    ))}
    <div class="xo-progressive-blur"></div>
  </div>
</div>

<script>
  function initTraceDemos() {
    const demos = document.querySelectorAll<HTMLElement>('[data-trace-demo]');
    demos.forEach((demo) => {
      if (demo.dataset.initialized) return;
      demo.dataset.initialized = 'true';

      const steps = JSON.parse(demo.dataset.steps || '[]');
      const lines = demo.querySelectorAll<HTMLElement>('[data-trace-line]');
      const bar = demo.querySelector<HTMLElement>('[data-trace-bar]');
      const progressText = demo.querySelector<HTMLElement>('[data-trace-progress-text]');
      const progressLabel = demo.dataset.progressLabel || '';

      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (reduced) {
        lines.forEach((l) => l.classList.add('is-visible'));
        if (bar) bar.style.width = '100%';
        return;
      }

      let stepIndex = 0;
      let interval: number | undefined;

      function showStep() {
        if (stepIndex >= steps.length) {
          // Reset after a pause
          setTimeout(() => {
            lines.forEach((l) => l.classList.remove('is-visible'));
            if (bar) bar.style.width = '0%';
            if (progressText) progressText.textContent = '0%';
            stepIndex = 0;
            setTimeout(showStep, 300);
          }, 3000);
          return;
        }

        const line = lines[stepIndex];
        const step = steps[stepIndex];
        if (line) line.classList.add('is-visible');

        if (step.progress !== undefined && bar) {
          bar.style.width = step.progress + '%';
          if (progressText) progressText.textContent = step.progress + '%';
        }

        stepIndex++;
        const delay = step.prompt === '◆' || step.prompt === '✓' ? 800 : 500;
        interval = window.setTimeout(showStep, delay);
      }

      // Start when scrolled into view
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              setTimeout(showStep, 400);
              observer.disconnect();
            }
          });
        },
        { threshold: 0.3 }
      );
      observer.observe(demo);
    });
  }

  initTraceDemos();
  document.addEventListener('astro:after-swap', initTraceDemos);
</script>
