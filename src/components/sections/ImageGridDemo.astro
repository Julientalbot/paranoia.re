---
interface GridImage {
  src: string;
  alt: string;
  caption?: string;
  span?: 'large' | 'normal';
}

interface Props {
  images: GridImage[];
  class?: string;
}

const { images, class: className } = Astro.props;
---

<div class:list={['xo-image-grid', className]}>
  {images.map((image) => (
    <figure class:list={['xo-image-grid__cell', { 'is-large': image.span === 'large' }]}>
      <img src={image.src} alt={image.alt} loading="lazy" decoding="async" />
      {image.caption && <figcaption class="xo-image-grid__caption">{image.caption}</figcaption>}
    </figure>
  ))}
</div>

<style>
  .xo-image-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-auto-rows: minmax(8rem, auto);
    gap: 3px;
    overflow: hidden;
    border-radius: var(--eco-radius-panel, 12px);
    border: 1px solid var(--xo-line);
    background: var(--xo-line);
  }

  .xo-image-grid__cell {
    position: relative;
    overflow: hidden;
    margin: 0;
    background: var(--xo-surface);
  }

  .xo-image-grid__cell.is-large {
    grid-column: span 2;
    grid-row: span 2;
  }

  .xo-image-grid__cell img {
    object-fit: cover;
    width: 100%;
    height: 100%;
    min-height: 100%;
    display: block;
    transition: transform 500ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .xo-image-grid__cell:hover img {
    transform: scale(1.04);
  }

  .xo-image-grid__caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.6rem;
    background: rgba(5, 5, 5, 0.84);
    color: #fff;
    font-family: var(--eco-font-mono);
    font-size: 0.7rem;
    opacity: 0;
    transition: opacity 200ms ease;
    pointer-events: none;
  }

  .xo-image-grid__cell:hover .xo-image-grid__caption {
    opacity: 1;
  }

  @media (max-width: 640px) {
    .xo-image-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-auto-rows: minmax(6rem, auto);
    }
  }

  @media (max-width: 400px) {
    .xo-image-grid {
      grid-template-columns: 1fr;
    }

    .xo-image-grid__cell.is-large {
      grid-column: span 1;
      grid-row: span 1;
    }
  }
</style>
