---
import { PARANOIA_CONTACT_HREF } from '../lib/contact';

interface Props {
  ctaHref?: string;
  ctaLabel?: string;
}

const { ctaHref = PARANOIA_CONTACT_HREF, ctaLabel = 'Demander un accès pilote' } = Astro.props;
---

<header class="site-header">
  <nav class="xo-shell xo-nav" aria-label="Navigation principale">
    <a class="xo-brand" href="/" aria-label="Paranoia accueil">
      <span class="xo-brand-mark" aria-hidden="true">
        <img src="/logo-mark.svg" alt="" width="38" height="38" loading="eager" decoding="async" />
      </span>
      <span>Paranoia</span>
    </a>
    <div class="xo-nav-links">
      <a href="/#workflow">Produit</a>
      <a href="/#limits">Limites</a>
      <a href="/rapports-incidents">Transparence</a>
      <a href={ctaHref} data-event="nav_primary_cta_click">{ctaLabel}</a>
    </div>
  </nav>
</header>
