---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PARANOIA_CONTACT_EMAIL, PARANOIA_CONTACT_HREF } from '../lib/contact';

const before =
  'Peux-tu résumer le contrat Atelier Kanopé ? Contact : Maya Hoarau, direction ops, maya.hoarau@atelier-kanope.example. Dossier fournisseur K-47B. Inclure la clause 4.2.';
const after =
  'Peux-tu résumer le contrat [Organisation] ? Contact : [Prénom] [Nom], [Rôle], [Email]. Dossier fournisseur [Identifiant]. Inclure la clause 4.2.';

const reviewTabs = [
  {
    id: 'raw',
    label: 'Brut',
    code: before,
  },
  {
    id: 'masked',
    label: 'Masqué',
    code: after,
  },
  {
    id: 'control',
    label: 'Contrôle',
    code: `review_state: required
detected_fields: personne, email, organisation, rôle, identifiant
rule: mask before send
limit: not a DLP replacement`,
  },
];

const workflowSteps = [
  {
    label: '01 détecter',
    title: 'Voir les champs exposés.',
    body: 'Noms, emails, organisations, rôles, identifiants et fragments sensibles sont rendus visibles avant transmission.',
  },
  {
    label: '02 masquer',
    title: 'Produire une version réduite.',
    body: 'Le prompt garde son intention de travail, mais remplace les données directes par des libellés contrôlables.',
  },
  {
    label: '03 relire',
    title: 'Garder la décision humaine.',
    body: 'L’utilisateur accepte, corrige ou retire ce qui ne doit pas quitter le poste.',
  },
  {
    label: '04 envoyer',
    title: 'Transmettre seulement la version relue.',
    body: 'Paranoia réduit l’exposition avant l’assistant IA. Il ne transforme pas un secret brut en donnée partageable.',
  },
];

const limits = [
  {
    label: 'Périmètre',
    title: 'Réduction d’exposition, pas DLP.',
    body: 'Paranoia intervient avant l’envoi d’un prompt. Il ne contrôle pas tout le système d’information.',
  },
  {
    label: 'Responsabilité',
    title: 'La relecture reste obligatoire.',
    body: 'Le produit rend l’exposition visible ; l’équipe garde la décision sur ce qui peut partir.',
  },
  {
    label: 'Conformité',
    title: 'Aucune conformité magique.',
    body: 'Les obligations juridiques, contractuelles et organisationnelles restent à traiter avec leurs propriétaires.',
  },
];

const fitItems = [
  {
    label: 'Pour',
    title: 'Contrats, clients, RH, support, opérations.',
    body: 'Équipes qui copient déjà du travail réel dans des assistants IA et veulent un contrôle avant envoi.',
  },
  {
    label: 'Pour',
    title: 'Pilotes IA avec risque visible.',
    body: 'Organisations qui veulent documenter ce qui part, ce qui est masqué et ce qui reste hors assistant.',
  },
  {
    label: 'Pas pour',
    title: 'Autoriser l’envoi de secrets bruts.',
    body: 'Un secret qui ne doit pas sortir doit rester hors prompt. Le masquage ne remplace pas l’interdiction.',
  },
  {
    label: 'Pas pour',
    title: 'Remplacer la politique sécurité.',
    body: 'Paranoia est une étape de contrôle locale, pas une gouvernance complète de l’IA.',
  },
];

const contactHints = [
  {
    label: '01 situation',
    title: 'assistant',
    body: 'Quel assistant reçoit les prompts aujourd’hui.',
  },
  {
    label: '02 données',
    title: 'contenus',
    body: 'Quels contenus sensibles sont copiés avant envoi.',
  },
  {
    label: '03 contrainte',
    title: 'limite',
    body: 'Quelle règle, limite ou trace doit rester visible.',
  },
];
---

<BaseLayout title="Paranoia — réduire l’exposition des prompts IA">
  <main id="main" class="xo-page xo-page--product xo-home">
    <section class="xo-shell xo-hero xo-hero--split xo-home-hero" aria-labelledby="home-title">
      <div>
        <p class="xo-kicker">Confidentialité des prompts IA · pilote privé</p>
        <h1 id="home-title" class="xo-title xo-title--wide">Réduire l’exposition avant l’envoi.</h1>
        <p class="xo-subtitle">
          Paranoia détecte, masque et fait relire les contenus sensibles d’un prompt avant usage d’un assistant IA.
          Un seul rôle : rendre visible ce qui risque de sortir.
        </p>
        <div class="xo-actions">
          <a class="xo-button xo-button--primary" href={PARANOIA_CONTACT_HREF} data-event="primary_cta_click">Demander un accès pilote</a>
          <a class="xo-button" href="/rapports-incidents" data-event="transparency_click">Voir la transparence</a>
        </div>
      </div>

      <div class="xo-console paranoia-review-artifact xo-hero-artifact" data-code-artifact aria-label="Avant après prompt">
        <div class="xo-console-top">
          <span class="xo-console-dot"></span>
          <span class="xo-console-dot"></span>
          <span class="xo-console-dot"></span>
          <strong>prompt/review</strong>
          <button class="xo-copy-button paranoia-console-copy" type="button" data-copy-current>
            <span class="xo-copy-label">Copier</span>
          </button>
        </div>
        <div class="xo-console-body paranoia-review-body">
          <div class="paranoia-exposure">
            <div>
              <span>exposition</span>
              <strong>5 champs sensibles détectés</strong>
            </div>
            <div class="paranoia-exposure-bar" aria-hidden="true"><i></i></div>
          </div>
          <div class="paranoia-token-grid" role="list" aria-label="Types de données détectées">
            <span role="listitem">personne</span>
            <span role="listitem">email</span>
            <span role="listitem">org</span>
            <span role="listitem">rôle</span>
            <span role="listitem">id</span>
          </div>
          <div class="xo-code-tabs paranoia-review-tabs" role="tablist" aria-label="États du prompt">
            {reviewTabs.map((tab, index) => (
              <button
                class="xo-code-tab"
                type="button"
                role="tab"
                data-code-tab={tab.id}
                aria-selected={index === 0 ? 'true' : 'false'}
                tabindex={index === 0 ? '0' : '-1'}
              >
                {tab.label}
              </button>
            ))}
          </div>
          {reviewTabs.map((tab, index) => (
            <div class="xo-code-panel paranoia-review-panel" data-code-panel={tab.id} hidden={index !== 0}>
              <pre><code>{tab.code}</code></pre>
            </div>
          ))}
          <div class="paranoia-policy-stack" role="list" aria-label="Contrôles avant envoi">
            <div role="listitem"><span>règle</span><strong>mask before send</strong></div>
            <div role="listitem"><span>état</span><strong>review required</strong></div>
            <div role="listitem"><span>limite</span><strong>not a DLP replacement</strong></div>
          </div>
        </div>
      </div>
    </section>

    <section id="workflow" class="xo-shell xo-section xo-compact-section" aria-labelledby="workflow-title">
      <div class="xo-proof-layout">
        <div class="xo-proof-copy">
          <p class="xo-kicker">Produit</p>
          <h2 id="workflow-title" class="xo-title xo-title--section">Un geste avant l’assistant.</h2>
          <p>
            Paranoia ne cherche pas à tout gouverner. Il ajoute une étape lisible entre le travail réel
            et l’assistant IA : inspecter, masquer, relire, puis décider.
          </p>
        </div>
        <div class="xo-field-ledger" aria-label="Flux de réduction d'exposition avant envoi">
          {workflowSteps.map((item, index) => (
            <div class={index === workflowSteps.length - 1 ? 'is-output' : ''}>
              <span>{item.label}</span>
              <strong>{item.title}</strong>
              <p>{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="limits" class="xo-shell xo-section" aria-labelledby="limits-title">
      <div class="xo-proof-layout">
        <div class="xo-proof-copy">
          <p class="xo-kicker">Limites</p>
          <h2 id="limits-title" class="xo-title xo-title--section">Ce que Paranoia ne promet pas.</h2>
          <p>
            La confiance vient aussi de la limite. Le produit réduit une exposition identifiable ;
            il ne remplace ni une politique sécurité, ni une validation juridique, ni le jugement humain.
          </p>
        </div>
        <div class="xo-field-ledger" aria-label="Limites produit">
          {limits.map((item) => (
            <div>
              <span>{item.label}</span>
              <strong>{item.title}</strong>
              <p>{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="fit" class="xo-shell xo-section" aria-labelledby="fit-title">
      <div class="xo-proof-layout">
        <div class="xo-proof-copy">
          <p class="xo-kicker">Usage</p>
          <h2 id="fit-title" class="xo-title xo-title--section">Pour qui, pas pour qui.</h2>
          <p>
            Paranoia convient aux équipes qui utilisent déjà l’IA sur du travail sensible
            et veulent une barrière simple avant le copier-coller.
          </p>
        </div>
        <div class="xo-field-ledger" aria-label="Publics et limites Paranoia">
          {fitItems.map((item) => (
            <div>
              <span>{item.label}</span>
              <strong>{item.title}</strong>
              <p>{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="cta" class="xo-shell xo-section" aria-labelledby="start-title">
      <div class="xo-start-paths">
        <article class="xo-start-panel">
          <div>
            <p class="xo-label">Pilote privé</p>
            <h2 id="start-title">Demander un accès pilote.</h2>
          </div>
          <p>
            Envoyez trois lignes, pas un dossier. Le premier échange sert seulement à vérifier
            si Paranoia répond au risque réel.
          </p>
          <div class="paranoia-direct-contact" aria-label="Message utile pour demander un accès pilote">
            {contactHints.map((item) => (
              <div>
                <span>{item.label}</span>
                <strong>{item.title}</strong>
                <p>{item.body}</p>
              </div>
            ))}
          </div>
          <div class="xo-contact-actions">
            <a class="xo-button xo-button--primary" href={PARANOIA_CONTACT_HREF} data-event="contact_mail_click">Demander un accès pilote</a>
            <a class="xo-button" href="/rapports-incidents" data-event="transparency_click">Voir la transparence</a>
          </div>
          <p class="pilot-hint">Email direct : <a href={PARANOIA_CONTACT_HREF}>{PARANOIA_CONTACT_EMAIL}</a>.</p>
        </article>
        <a class="xo-path-card" href="/rapports-incidents" data-event="transparency_click">
          <div class="xo-path-artifact" aria-hidden="true">
            <div><span>01</span><strong>collecte</strong></div>
            <div><span>02</span><strong>conservation</strong></div>
            <div class="is-output"><span>03</span><strong>suppression</strong></div>
          </div>
          <div>
            <p class="xo-label">Transparence</p>
            <h3>Ce qui est envoyé, ce qui ne l’est pas.</h3>
            <p>Rapports techniques, prompts, conservation, support et suppression sont documentés sur une seule page.</p>
          </div>
          <span class="xo-card-arrow">Lire la transparence →</span>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
