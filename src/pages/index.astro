---
import BaseLayout from '../layouts/BaseLayout.astro';
import WaitlistForm from '../components/WaitlistForm.astro';
import { PARANOIA_CONTACT_EMAIL, PARANOIA_CONTACT_HREF } from '../lib/contact';

const capabilities = [
  {
    href: '#detecte',
    label: 'Detect',
    title: 'Repérer les données sensibles.',
    body: 'Données personnelles, emails, identifiants, clauses, secrets internes et contexte client.',
  },
  {
    href: '#protege',
    label: 'Protect',
    title: 'Réduire l’exposition avant l’envoi.',
    body: 'Masquage, pseudonymisation ou reformulation selon la politique retenue par l’équipe.',
  },
  {
    href: '#review',
    label: 'Review',
    title: 'Rendre le départ visible.',
    body: 'L’utilisateur relit l’avant/après et garde la responsabilité du prompt transmis.',
  },
  {
    href: '/rapports-incidents',
    label: 'Trust',
    title: 'Documenter les limites.',
    body: 'Incidents, traitements séparés, support et limites à lire avant un usage sensible.',
  },
];

const proofClaims = [
  {
    label: 'claim',
    title: 'Réduire l’exposition avant l’assistant.',
    body: 'Paranoia traite le prompt comme une surface à inspecter, pas comme un champ texte neutre.',
  },
  {
    label: 'policy',
    title: 'Montrer la règle appliquée.',
    body: 'Détection, masquage et relecture doivent rester visibles avant tout envoi.',
  },
  {
    label: 'limit',
    title: 'Documenter ce que le produit ne fait pas.',
    body: 'La confiance vient aussi des incidents, des limites et du support accessibles.',
  },
];

const before =
  'Peux-tu résumer le contrat Atelier Kanopé ? Contact : Maya Hoarau, direction ops, maya.hoarau@atelier-kanope.example. Dossier fournisseur K-47B. Inclure la clause 4.2.';
const after =
  'Peux-tu résumer le contrat [Organisation] ? Contact : [Prénom] [Nom], [Rôle], [Email]. Dossier fournisseur [Identifiant]. Inclure la clause 4.2.';
---

<BaseLayout title="Paranoia — réduire les données sensibles envoyées aux assistants IA">
  <main class="xo-page xo-page--product">
    <div class="xo-shell">
      <nav class="xo-nav" aria-label="Navigation principale">
        <a class="xo-brand" href="/" aria-label="Paranoia accueil">
          <span class="xo-brand-mark" aria-hidden="true">
            <img src="/logo-mark.svg" alt="" width="38" height="38" loading="eager" decoding="async" />
          </span>
          <span>Paranoia</span>
        </a>
        <div class="xo-nav-links">
          <a href="#detecte">Produit</a>
          <a href="/rapports-incidents">Incidents</a>
          <a href="#cta">Beta</a>
          <a href={PARANOIA_CONTACT_HREF}>Contact</a>
        </div>
      </nav>
    </div>

    <section class="xo-shell xo-hero xo-hero--split" aria-labelledby="home-title">
      <div>
        <p class="xo-kicker">Confidentialité des prompts IA · beta privée</p>
        <h1 id="home-title" class="xo-title xo-title--wide">Réduire l’exposition des prompts IA.</h1>
        <p class="xo-subtitle">
          Paranoia est un produit séparé de confidentialité et d’exposition des prompts. Il aide les équipes à détecter,
          masquer et relire les contenus sensibles avant l’usage d’un assistant IA. Il réduit une surface d’exposition ;
          il ne remplace pas une politique de sécurité.
        </p>
        <div class="xo-actions" style="margin-top: var(--eco-space-6)">
          <a class="xo-button xo-button--primary" href="#cta">Rejoindre la beta</a>
          <a class="xo-button" href={PARANOIA_CONTACT_HREF}>Parler d’un pilote</a>
          <a class="xo-button" href="/rapports-incidents">Lire les incidents</a>
        </div>
      </div>

      <div class="xo-console paranoia-review-artifact" aria-label="Avant après prompt">
        <div class="xo-console-top">
          <span class="xo-console-dot"></span>
          <span class="xo-console-dot"></span>
          <span class="xo-console-dot"></span>
          <strong>prompt/review</strong>
        </div>
        <div class="xo-console-body paranoia-review-body">
          <div class="paranoia-exposure">
            <div>
              <span>exposure</span>
              <strong>5 champs sensibles détectés</strong>
            </div>
            <div class="paranoia-exposure-bar" aria-hidden="true"><i></i></div>
          </div>
          <div class="paranoia-token-grid" aria-label="Types de données détectées">
            <span>person</span>
            <span>email</span>
            <span>org</span>
            <span>role</span>
            <span>id</span>
          </div>
          <div class="xo-console-line"><span>raw</span><span>{before}</span></div>
          <div class="xo-console-line"><span>mask</span><strong>{after}</strong></div>
          <div class="paranoia-policy-stack" aria-label="Contrôles avant envoi">
            <div><span>policy</span><strong>mask before send</strong></div>
            <div><span>state</span><strong>review required</strong></div>
            <div><span>limit</span><strong>not a DLP replacement</strong></div>
          </div>
        </div>
      </div>
    </section>

    <section class="xo-shell xo-proof-claim-grid" aria-label="Grammaire de preuve Paranoia">
      {proofClaims.map((item) => (
        <article>
          <span>{item.label}</span>
          <strong>{item.title}</strong>
          <p>{item.body}</p>
        </article>
      ))}
    </section>

    <section class="xo-shell" aria-label="Capacités Paranoia">
      <div class="xo-capability-grid">
        {capabilities.map((item, index) => (
          <a id={index === 0 ? 'detecte' : index === 1 ? 'protege' : index === 2 ? 'review' : undefined} class="xo-card" href={item.href}>
            <div class="xo-demo" aria-hidden="true">
              <div class="xo-console-body" style="padding: 0">
                <div class="xo-console-line"><span>{String(index + 1).padStart(2, '0')}</span><span>{item.label.toLowerCase()}</span></div>
                <div class="xo-console-line"><span>policy</span><span>{item.body}</span></div>
                <div class="xo-console-line"><span>state</span><strong>beta · qualified pilots</strong></div>
              </div>
            </div>
            <div>
              <p class="xo-label">{item.label}</p>
              <h2>{item.title}</h2>
              <p>{item.body}</p>
            </div>
            <span class="xo-card-arrow">Explorer →</span>
          </a>
        ))}
      </div>
    </section>

    <section class="xo-shell xo-section">
      <div class="xo-metric-strip" aria-label="Repères produit qualifiés">
        <div class="xo-metric"><strong>Local</strong><span>Contenu traité côté poste selon la conception visée.</span></div>
        <div class="xo-metric"><strong>Policy</strong><span>Règles ajustables selon contexte et équipe pilote.</span></div>
        <div class="xo-metric"><strong>Review</strong><span>Avant/après inspectable avant transmission.</span></div>
        <div class="xo-metric"><strong>Limits</strong><span>Documentation sécurité à compléter avant déploiement sensible.</span></div>
      </div>
    </section>

    <section id="cta" class="xo-shell xo-section">
      <p class="xo-kicker">Choisir par où commencer</p>
      <div class="xo-start-paths" style="margin-top: var(--eco-space-5)">
        <div class="xo-start-card">
          <div>
            <p class="xo-label">Beta</p>
            <h2>Décrire un cas d’usage sensible.</h2>
          </div>
          <p>Assistant utilisé, types de données copiées, politique à tenir, contraintes de support et de sécurité.</p>
          <WaitlistForm />
          <p class="hint">
            Question directe ou pilote déjà identifié ?
            <a href={PARANOIA_CONTACT_HREF}>Écrire à {PARANOIA_CONTACT_EMAIL}</a>.
          </p>
        </div>
        <a class="xo-start-card" href="/rapports-incidents">
          <div>
            <p class="xo-label">Transparence</p>
            <h2>Lire les rapports d’incidents.</h2>
          </div>
          <p>Sentry, conservation, signalement manuel et limites de collecte sont documentés séparément.</p>
          <span class="xo-card-arrow">Ouvrir /rapports-incidents →</span>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
