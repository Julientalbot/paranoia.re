---
import BaseLayout from '../layouts/BaseLayout.astro';
import WaitlistForm from '../components/WaitlistForm.astro';
import { PARANOIA_CONTACT_EMAIL, PARANOIA_CONTACT_HREF } from '../lib/contact';

const paths = [
  {
    href: '#workflow',
    label: 'Fonctionnement',
    title: 'Inspecter avant d’envoyer.',
    body: 'Le prompt est traité comme une surface produit : détection, masquage, relecture, décision.',
    steps: ['detect', 'mask', 'review'],
  },
  {
    href: '#limits',
    label: 'Limites',
    title: 'Voir ce que le produit ne promet pas.',
    body: 'Paranoia réduit une exposition. Il ne remplace ni DLP, ni politique sécurité, ni responsabilité humaine.',
    steps: ['scope', 'risk', 'human'],
  },
  {
    href: '/rapports-incidents',
    label: 'Incidents',
    title: 'Lire le journal de confiance.',
    body: 'Rapports, collecte, signalement manuel, support et limites sont documentés séparément.',
    steps: ['report', 'support', 'trace'],
  },
  {
    href: '#cta',
    label: 'Waitlist',
    title: 'Décrire un cas pilote.',
    body: 'Assistant utilisé, données copiées, politique à tenir, contraintes support et sécurité.',
    steps: ['case', 'policy', 'pilot'],
  },
];

const before =
  'Peux-tu résumer le contrat Atelier Kanopé ? Contact : Maya Hoarau, direction ops, maya.hoarau@atelier-kanope.example. Dossier fournisseur K-47B. Inclure la clause 4.2.';
const after =
  'Peux-tu résumer le contrat [Organisation] ? Contact : [Prénom] [Nom], [Rôle], [Email]. Dossier fournisseur [Identifiant]. Inclure la clause 4.2.';

const limits = [
  {
    label: 'Scope',
    title: 'Réduction d’exposition',
    body: 'Le produit aide avant l’envoi vers un assistant IA. Il ne garantit pas la conformité complète d’une organisation.',
  },
  {
    label: 'Contrôle',
    title: 'Relecture humaine',
    body: 'L’utilisateur doit voir l’avant/après et garder la responsabilité du prompt transmis.',
  },
  {
    label: 'Trust',
    title: 'Incidents séparés',
    body: 'Les limites, incidents, traitements et supports sont publiés dans une page dédiée.',
  },
];
---

<BaseLayout title="Paranoia — réduire les données sensibles envoyées aux assistants IA">
  <main class="xo-page xo-page--product xai-home">
    <div class="xo-shell">
      <nav class="xo-nav" aria-label="Navigation principale">
        <a class="xo-brand" href="/" aria-label="Paranoia accueil">
          <span class="xo-brand-mark" aria-hidden="true">
            <img src="/logo-mark.svg" alt="" width="38" height="38" loading="eager" decoding="async" />
          </span>
          <span>Paranoia</span>
        </a>
        <div class="xo-nav-links">
          <a href="#workflow">Produit</a>
          <a href="#limits">Limites</a>
          <a href="/rapports-incidents">Incidents</a>
          <a href="#cta">Beta</a>
          <a href={PARANOIA_CONTACT_HREF}>Contact</a>
        </div>
      </nav>
    </div>

    <section class="xo-shell xo-hero xo-hero--split xai-home-hero" aria-labelledby="home-title">
      <div>
        <p class="xo-kicker">Confidentialité des prompts IA · beta privée</p>
        <h1 id="home-title" class="xo-title xo-title--wide">Inspecter avant d’envoyer.</h1>
        <p class="xo-subtitle">
          Paranoia aide à détecter, masquer et relire les contenus sensibles avant l’usage d’un assistant IA.
          Il réduit une surface d’exposition ; il ne remplace pas une politique de sécurité.
        </p>
        <div class="xo-actions" style="margin-top: var(--eco-space-6)">
          <a class="xo-button xo-button--primary" href="#cta">Rejoindre la beta</a>
          <a class="xo-button" href="/rapports-incidents">Lire les incidents</a>
        </div>
      </div>

      <div class="xo-console paranoia-review-artifact xai-hero-artifact" aria-label="Avant après prompt">
        <div class="xo-console-top">
          <span class="xo-console-dot"></span>
          <span class="xo-console-dot"></span>
          <span class="xo-console-dot"></span>
          <strong>prompt/review</strong>
        </div>
        <div class="xo-console-body paranoia-review-body">
          <div class="paranoia-exposure">
            <div>
              <span>exposure</span>
              <strong>5 champs sensibles détectés</strong>
            </div>
            <div class="paranoia-exposure-bar" aria-hidden="true"><i></i></div>
          </div>
          <div class="paranoia-token-grid" aria-label="Types de données détectées">
            <span>person</span>
            <span>email</span>
            <span>org</span>
            <span>role</span>
            <span>id</span>
          </div>
          <div class="xo-console-line"><span>raw</span><span>{before}</span></div>
          <div class="xo-console-line"><span>mask</span><strong>{after}</strong></div>
          <div class="paranoia-policy-stack" aria-label="Contrôles avant envoi">
            <div><span>policy</span><strong>mask before send</strong></div>
            <div><span>state</span><strong>review required</strong></div>
            <div><span>limit</span><strong>not a DLP replacement</strong></div>
          </div>
        </div>
      </div>
    </section>

    <section id="workflow" class="xo-shell xo-section xai-compact-section" aria-labelledby="paths-title">
      <div class="xo-section-heading">
        <div>
          <p class="xo-kicker">Produit</p>
          <h2 id="paths-title" class="xo-title xo-title--section">Quatre surfaces à inspecter.</h2>
        </div>
        <p>Chaque chemin mène vers une action ou une information de confiance. Rien n’est posé comme simple effet visuel.</p>
      </div>

      <div class="xai-path-grid" aria-label="Chemins Paranoia">
        {paths.map((item, index) => (
          <a class:list={['xai-path-card', index === 0 && 'xai-path-card--primary']} href={item.href}>
            <div class="xai-path-artifact" aria-hidden="true">
              {item.steps.map((step, stepIndex) => (
                <div><span>{String(stepIndex + 1).padStart(2, '0')}</span><strong>{step}</strong></div>
              ))}
            </div>
            <div>
              <p class="xo-label">{item.label}</p>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </div>
            <span class="xo-card-arrow">Explorer →</span>
          </a>
        ))}
      </div>
    </section>

    <section id="limits" class="xo-shell xo-section" aria-labelledby="limits-title">
      <div class="xai-proof-layout">
        <div class="xai-proof-copy">
          <p class="xo-kicker">Trust</p>
          <h2 id="limits-title" class="xo-title xo-title--section">La limite fait partie du produit.</h2>
          <p>
            Une page produit crédible ne cache pas son périmètre. Paranoia doit montrer le contrôle,
            l’avant/après et ce qui reste à la charge de l’équipe.
          </p>
        </div>
        <div class="xai-field-ledger" aria-label="Limites produit">
          {limits.map((item) => (
            <div>
              <span>{item.label}</span>
              <strong>{item.title}</strong>
              <p>{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="cta" class="xo-shell xo-section" aria-labelledby="start-title">
      <div class="xo-section-heading">
        <div>
          <p class="xo-kicker">Commencer</p>
          <h2 id="start-title" class="xo-title xo-title--section">Piloter ou lire les limites.</h2>
        </div>
        <p>Deux suites possibles : décrire un cas réel ou inspecter le journal de confiance.</p>
      </div>

      <div class="xo-start-paths">
        <div class="xo-start-card">
          <div>
            <p class="xo-label">Beta</p>
            <h2>Décrire un cas d’usage sensible.</h2>
          </div>
          <p>Assistant utilisé, types de données copiées, politique à tenir, contraintes de support et de sécurité.</p>
          <WaitlistForm />
          <p class="hint">
            Question directe ou pilote déjà identifié ?
            <a href={PARANOIA_CONTACT_HREF}>Écrire à {PARANOIA_CONTACT_EMAIL}</a>.
          </p>
        </div>
        <a class="xo-start-card" href="/rapports-incidents">
          <div>
            <p class="xo-label">Transparence</p>
            <h2>Lire les rapports d’incidents.</h2>
          </div>
          <p>Sentry, conservation, signalement manuel et limites de collecte sont documentés séparément.</p>
          <span class="xo-card-arrow">Ouvrir /rapports-incidents →</span>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
