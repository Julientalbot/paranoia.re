---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import WaitlistForm from '../components/WaitlistForm.astro';
import { PARANOIA_CONTACT_EMAIL, PARANOIA_CONTACT_HREF } from '../lib/contact';

const paths = [
  {
    href: '#workflow',
    label: 'Fonctionnement',
    title: 'Inspecter avant d’envoyer.',
    body: 'Le prompt est traité comme une surface produit : détection, masquage, relecture, décision.',
    steps: ['detect', 'mask', 'review'],
  },
  {
    href: '#limits',
    label: 'Limites',
    title: 'Voir ce que le produit ne promet pas.',
    body: 'Paranoia réduit une exposition. Il ne remplace ni DLP, ni politique sécurité, ni responsabilité humaine.',
    steps: ['scope', 'risk', 'human'],
  },
  {
    href: '/rapports-incidents',
    label: 'Incidents',
    title: 'Lire le journal de confiance.',
    body: 'Rapports, collecte, signalement manuel, support et limites sont documentés séparément.',
    steps: ['report', 'support', 'trace'],
  },
  {
    href: '#cta',
    label: 'Waitlist',
    title: 'Décrire un cas pilote.',
    body: 'Assistant utilisé, données copiées, politique à tenir, contraintes support et sécurité.',
    steps: ['case', 'policy', 'pilot'],
  },
];

const before =
  'Peux-tu résumer le contrat Atelier Kanopé ? Contact : Maya Hoarau, direction ops, maya.hoarau@atelier-kanope.example. Dossier fournisseur K-47B. Inclure la clause 4.2.';
const after =
  'Peux-tu résumer le contrat [Organisation] ? Contact : [Prénom] [Nom], [Rôle], [Email]. Dossier fournisseur [Identifiant]. Inclure la clause 4.2.';

const dataFlow = [
  {
    label: '01 prompt entrant',
    title: 'Le texte reste lisible avant décision.',
    body: 'L’utilisateur voit le contenu brut et les zones qui risquent d’exposer une personne, une organisation ou un identifiant.',
  },
  {
    label: '02 champs détectés',
    title: 'Les catégories sensibles sont visibles.',
    body: 'Personne, email, organisation, rôle, identifiant ou fragment contractuel sont signalés avant transmission.',
  },
  {
    label: '03 sortie masquée',
    title: 'Une version réduite est proposée.',
    body: 'Le prompt peut remplacer les données directes par des libellés contrôlables sans changer l’intention de travail.',
  },
  {
    label: '04 décision humaine',
    title: 'La relecture reste obligatoire.',
    body: 'L’utilisateur choisit quoi accepter, corriger ou garder hors assistant. Paranoia ne retire pas la responsabilité.',
  },
  {
    label: '05 envoi',
    title: 'Seule la version relue part vers l’assistant.',
    body: 'Le produit réduit l’exposition avant envoi ; il ne rend pas sûr l’envoi de secrets bruts.',
  },
];

const fitItems = [
  {
    label: 'Pour',
    title: 'Données client, contrat, RH, support ou internes.',
    body: 'Équipes qui copient déjà des informations sensibles dans des assistants IA et veulent une étape de contrôle.',
  },
  {
    label: 'Pour',
    title: 'Relecture humaine avant transmission.',
    body: 'Organisations qui veulent rendre visible ce qui part, ce qui est masqué et ce qui doit rester sous responsabilité humaine.',
  },
  {
    label: 'Pas pour',
    title: 'Remplacer une DLP ou une politique sécurité.',
    body: 'Paranoia est une réduction d’exposition avant prompt, pas un contrôle global du système d’information.',
  },
  {
    label: 'Pas pour',
    title: 'Garantir une conformité complète.',
    body: 'Le produit n’efface pas les obligations juridiques, contractuelles, organisationnelles ou humaines.',
  },
  {
    label: 'Pas pour',
    title: 'Rendre sûr l’envoi de secrets bruts.',
    body: 'Un secret qui ne doit pas sortir doit rester hors assistant. Le masquage n’autorise pas tout envoi.',
  },
];

const limits = [
  {
    label: 'Scope',
    title: 'Réduction d’exposition',
    body: 'Le produit aide avant l’envoi vers un assistant IA. Il ne garantit pas la conformité complète d’une organisation.',
  },
  {
    label: 'Contrôle',
    title: 'Relecture humaine',
    body: 'L’utilisateur doit voir l’avant/après et garder la responsabilité du prompt transmis.',
  },
  {
    label: 'Trust',
    title: 'Incidents séparés',
    body: 'Les limites, incidents, traitements et supports sont publiés dans une page dédiée.',
  },
];
---

<BaseLayout title="Paranoia — réduire les données sensibles envoyées aux assistants IA">
  <main class="xo-page xo-page--product xo-home">
    <Header ctaHref="#cta" ctaLabel="Beta" />

    <section class="xo-shell xo-hero xo-hero--split xo-home-hero" aria-labelledby="home-title">
      <div>
        <p class="xo-kicker">Confidentialité des prompts IA · beta privée</p>
        <h1 id="home-title" class="xo-title xo-title--wide">Inspecter avant d’envoyer.</h1>
        <p class="xo-subtitle">
          Paranoia aide à détecter, masquer et relire les contenus sensibles avant l’usage d’un assistant IA.
          Il réduit une surface d’exposition ; il ne remplace pas une politique de sécurité.
        </p>
        <div class="xo-actions">
          <a class="xo-button xo-button--primary" href="#cta" data-event="primary_cta_click">Rejoindre la beta</a>
          <a class="xo-button" href="/rapports-incidents" data-event="incident_reports_click">Lire les incidents</a>
        </div>
      </div>

      <div class="xo-console paranoia-review-artifact xo-hero-artifact" aria-label="Avant après prompt">
        <div class="xo-console-top">
          <span class="xo-console-dot"></span>
          <span class="xo-console-dot"></span>
          <span class="xo-console-dot"></span>
          <strong>prompt/review</strong>
        </div>
        <div class="xo-console-body paranoia-review-body">
          <div class="paranoia-exposure">
            <div>
              <span>exposure</span>
              <strong>5 champs sensibles détectés</strong>
            </div>
            <div class="paranoia-exposure-bar" aria-hidden="true"><i></i></div>
          </div>
          <div class="paranoia-token-grid" aria-label="Types de données détectées">
            <span>person</span>
            <span>email</span>
            <span>org</span>
            <span>role</span>
            <span>id</span>
          </div>
          <div class="xo-console-line"><span>raw</span><span>{before}</span></div>
          <div class="xo-console-line"><span>mask</span><strong>{after}</strong></div>
          <div class="paranoia-policy-stack" aria-label="Contrôles avant envoi">
            <div><span>policy</span><strong>mask before send</strong></div>
            <div><span>state</span><strong>review required</strong></div>
            <div><span>limit</span><strong>not a DLP replacement</strong></div>
          </div>
        </div>
      </div>
    </section>

    <section id="workflow" class="xo-shell xo-section xo-compact-section" aria-labelledby="paths-title">
      <div class="xo-section-heading">
        <div>
          <p class="xo-kicker">Produit</p>
          <h2 id="paths-title" class="xo-title xo-title--section">Quatre surfaces à inspecter.</h2>
        </div>
        <p>Chaque chemin mène vers une action ou une information de confiance. Rien n’est posé comme simple effet visuel.</p>
      </div>

      <div class="xo-path-grid xo-path-grid--surfaces" aria-label="Chemins Paranoia">
        {paths.map((item, index) => (
          <a class:list={['xo-path-card', index === 0 && 'xo-path-card--primary']} href={item.href}>
            <div class="xo-path-artifact" aria-hidden="true">
              {item.steps.map((step, stepIndex) => (
                <div class={stepIndex === item.steps.length - 1 ? 'is-output' : ''}>
                  <span>{String(stepIndex + 1).padStart(2, '0')}</span>
                  <strong>{step}</strong>
                </div>
              ))}
            </div>
            <div>
              <p class="xo-label">{item.label}</p>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </div>
            <span class="xo-card-arrow">Explorer →</span>
          </a>
        ))}
      </div>
    </section>

    <section id="flow" class="xo-shell xo-section" aria-labelledby="flow-title">
      <div class="xo-proof-layout">
        <div class="xo-proof-copy">
          <p class="xo-kicker">Flux produit</p>
          <h2 id="flow-title" class="xo-title xo-title--section">Ce qui se passe avant l’envoi.</h2>
          <p>
            La preuve produit tient dans une séquence vérifiable : voir le prompt, détecter les champs,
            proposer une version masquée, relire, puis décider ce qui quitte l’interface.
          </p>
        </div>
        <div class="xo-field-ledger" aria-label="Flux de réduction d'exposition avant envoi">
          {dataFlow.map((item, index) => (
            <div class={index === dataFlow.length - 1 ? 'is-output' : ''}>
              <span>{item.label}</span>
              <strong>{item.title}</strong>
              <p>{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="limits" class="xo-shell xo-section" aria-labelledby="limits-title">
      <div class="xo-proof-layout">
        <div class="xo-proof-copy">
          <p class="xo-kicker">Trust</p>
          <h2 id="limits-title" class="xo-title xo-title--section">La limite fait partie du produit.</h2>
          <p>
            Une page produit crédible ne cache pas son périmètre. Paranoia doit montrer le contrôle,
            l’avant/après et ce qui reste à la charge de l’équipe.
          </p>
        </div>
        <div class="xo-field-ledger" aria-label="Limites produit">
          {limits.map((item) => (
            <div>
              <span>{item.label}</span>
              <strong>{item.title}</strong>
              <p>{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="fit" class="xo-shell xo-section" aria-labelledby="fit-title">
      <div class="xo-proof-layout">
        <div class="xo-proof-copy">
          <p class="xo-kicker">Usage</p>
          <h2 id="fit-title" class="xo-title xo-title--section">Pour qui, pas pour qui.</h2>
          <p>
            La limite fait partie de la confiance : Paranoia aide sur une étape précise du prompt,
            pas sur toute la politique de sécurité d’une organisation.
          </p>
        </div>
        <div class="xo-field-ledger" aria-label="Publics et limites Paranoia">
          {fitItems.map((item) => (
            <div>
              <span>{item.label}</span>
              <strong>{item.title}</strong>
              <p>{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="xo-shell xo-section xo-compact-section" aria-labelledby="latest-title">
      <div class="xo-section-heading">
        <div>
          <p class="xo-kicker">Latest</p>
          <h2 id="latest-title" class="xo-title xo-title--section">Suivi public du produit.</h2>
        </div>
        <p>Releases, statut beta et incidents — ce que Paranoia publie, daté.</p>
      </div>

      <div class="xo-latest-list" aria-label="Latest Paranoia">
        <a class="xo-latest-row" href="/rapports-incidents">
          <span>Trust</span>
          <strong>Rapports d'incidents Sentry</strong>
          <p>Diagnostic bugs et stabilité, conservation 90 jours max, prompts non collectés par défaut.</p>
        </a>
        <a class="xo-latest-row" href="#workflow">
          <span>Beta</span>
          <strong>Détection 5 catégories sensibles</strong>
          <p>Person, email, organisation, rôle, identifiant — masquage avant envoi avec relecture humaine.</p>
        </a>
        <a class="xo-latest-row" href="#limits">
          <span>Scope</span>
          <strong>Réduction d'exposition, pas DLP</strong>
          <p>Ce que le produit fait et ce qu'il ne fait pas — documenté côté limites.</p>
        </a>
      </div>
    </section>

    <section id="cta" class="xo-shell xo-section" aria-labelledby="start-title">
      <div class="xo-section-heading">
        <div>
          <p class="xo-kicker">Commencer</p>
          <h2 id="start-title" class="xo-title xo-title--section">Piloter ou lire les limites.</h2>
        </div>
        <p>Deux suites possibles : décrire un cas réel ou inspecter le journal de confiance.</p>
      </div>

      <div class="xo-start-paths">
        <div class="xo-start-panel">
          <div>
            <p class="xo-label">Beta</p>
            <h2>Décrire un cas d’usage sensible.</h2>
          </div>
          <p>Assistant utilisé, types de données copiées, politique à tenir, contraintes de support et de sécurité.</p>
          <WaitlistForm />
          <p class="waitlist-hint">
            Question directe ou pilote déjà identifié ?
            <a href={PARANOIA_CONTACT_HREF} data-event="contact_mail_click">Écrire à {PARANOIA_CONTACT_EMAIL}</a>.
          </p>
        </div>
        <a class="xo-path-card" href="/rapports-incidents" data-event="incident_reports_click">
          <div class="xo-path-artifact" aria-hidden="true">
            <div><span>01</span><strong>collecte</strong></div>
            <div><span>02</span><strong>conservation</strong></div>
            <div class="is-output"><span>03</span><strong>limites</strong></div>
          </div>
          <div>
            <p class="xo-label">Transparence</p>
            <h3>Lire les rapports d’incidents.</h3>
            <p>Sentry, conservation, signalement manuel et limites de collecte sont documentés séparément.</p>
          </div>
          <span class="xo-card-arrow">Ouvrir /rapports-incidents →</span>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
