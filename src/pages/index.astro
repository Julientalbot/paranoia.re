---
import BaseLayout from '../layouts/BaseLayout.astro';
import AgentTraceDemo from '../components/living-artefacts/AgentTraceDemo.astro';
import ChatBubbleDemo from '../components/living-artefacts/ChatBubbleDemo.astro';
import HeroHeadline from '../components/living-artefacts/HeroHeadline.astro';

import GridShimmer from '../components/living-artefacts/GridShimmer.astro';
import ArtefactCard from '../components/living-artefacts/ArtefactCard.astro';
import LivePulse from '../components/living-artefacts/LivePulse.astro';
import { PARANOIA_CONTACT_EMAIL, PARANOIA_CONTACT_HREF } from '../lib/contact';

const heroDetectSteps = [
  { prompt: '❯', text: 'Analyser le prompt avant envoi.', dim: true },
  { text: 'Scanning...', dim: true },
  { prompt: '▸', text: 'detect personne → "Maya Hoarau"', accent: true, progress: 20 },
  { prompt: '▸', text: 'detect email → maya.hoarau@atelier-kanope.example', accent: true, progress: 40 },
  { prompt: '▸', text: 'detect org → "Atelier Kanopé"', accent: true, progress: 60 },
  { prompt: '▸', text: 'detect id → "K-47B"', accent: true, progress: 80 },
  { prompt: '▸', text: 'detect rôle → "direction ops"', accent: true, progress: 100 },
  { prompt: '✓', text: '5 champs détectés. Masquage prêt.', accent: true },
  { text: 'rule: mask before send', dim: true },
  { text: 'state: review required', dim: true },
];

const transparencyRows = [
  { tag: '90j', label: 'Conservation 90 jours maximum.' },
  { tag: 'off', label: 'Prompts non stockés côté Paranoia.' },
  { tag: 'rm', label: 'Suppression sur demande.' },
];

const productFaq = {
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'À quoi sert Paranoia ?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Paranoia aide à détecter, masquer et relire les contenus sensibles d’un prompt avant envoi à un assistant IA.',
      },
    },
    {
      '@type': 'Question',
      name: 'Paranoia remplace-t-il une validation humaine ?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Non. La relecture humaine reste obligatoire avant l’envoi, surtout dans les contextes sensibles.',
      },
    },
    {
      '@type': 'Question',
      name: 'Paranoia stocke-t-il les prompts originaux ?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Les prompts originaux ne sont pas stockés côté Paranoia. Les rapports techniques sont documentés séparément sur la page transparence.',
      },
    },
  ],
};
---

<BaseLayout title="Paranoia — réduire l’exposition des prompts IA" structuredData={productFaq}>
  <main id="main" class="xo-page xo-page--product xo-home">
    <section class="xo-shell xo-home-hero xo-home-hero--stack" aria-labelledby="home-title">
      <div class="xo-hero-lead">
        <p class="xo-kicker">Confidentialité des prompts IA · pilote privé</p>
        <HeroHeadline
          id="home-title"
          class="xo-title--wide"
          text="Réduire l’exposition avant l’envoi."
        />
        <p class="xo-subtitle">
          Paranoia détecte, masque et fait relire les contenus sensibles d’un prompt avant usage d’un assistant IA.
          Un seul rôle : rendre visible ce qui risque de sortir.
        </p>
        <ul class="paranoia-hero-limits" aria-label="Limites du pilote Paranoia">
          <li>Avant l’envoi.</li>
          <li>Validation humaine.</li>
          <li>Prompts non stockés côté Paranoia.</li>
        </ul>
        <div class="xo-actions">
          <a class="xo-button xo-button--primary" href={PARANOIA_CONTACT_HREF} data-event="primary_cta_click">Demander un accès pilote</a>
          <a class="xo-button" href="/rapports-incidents" data-event="transparency_click">Voir la transparence</a>
        </div>
      </div>

      <div class="xo-hero-tray" aria-label="Quatre artefacts de la revue de prompt Paranoia">
        <ArtefactCard label="Détection" href="/securite" cta="Voir la sécurité →" ariaLabel="Détection des champs sensibles" event="security_click">
          <AgentTraceDemo
            title="paranoia/prompt-review"
            progressLabel="5 champs"
            steps={heroDetectSteps}
          />
        </ArtefactCard>

        <ArtefactCard label="Avant / après" href="/confidentialite-prompts-ia" cta="Voir la confidentialité →" ariaLabel="Prompt avant et après masquage" event="privacy_click">
          <ChatBubbleDemo
            messages={[
              { role: 'user', text: 'Peux-tu résumer le contrat Atelier Kanopé ? Contact : Maya Hoarau, direction ops, maya.hoarau@atelier-kanope.example. Dossier fournisseur K-47B. Inclure la clause 4.2.' },
              { role: 'assistant', text: 'Peux-tu résumer le contrat [Organisation] ? Contact : [Prénom] [Nom], [Rôle], [Email]. Dossier fournisseur [Identifiant]. Inclure la clause 4.2.' },
              { role: 'user', text: 'Quelle est la politique de conservation des prompts ?' },
              { role: 'assistant', text: 'Quelle est la politique de conservation des [documents] ?' },
            ]}
          />
        </ArtefactCard>

        <ArtefactCard label="Transparence" href="/rapports-incidents" cta="Lire la transparence →" ariaLabel="Transparence des données" event="transparency_click">
          <div class="xo-tile-stream">
            <div class="xo-tile-stream__head">
              <span>Données</span>
              <LivePulse label="documenté" />
            </div>
            {transparencyRows.map((row) => (
              <div class="xo-tile-stream__row">
                <span>{row.tag}</span>
                <strong>{row.label}</strong>
              </div>
            ))}
          </div>
        </ArtefactCard>

        <ArtefactCard label="Exposition" href="/securite" cta="Voir la sécurité →" ariaLabel="Champs sensibles détectés dans un prompt" event="security_click">
          <div class="paranoia-review-body">
            <div class="paranoia-exposure">
              <div>
                <span>exposition</span>
                <strong>5 champs sensibles détectés</strong>
              </div>
              <div class="paranoia-exposure-bar" aria-hidden="true"><i></i></div>
            </div>
            <div class="paranoia-token-grid" role="list" aria-label="Types de données détectées">
              <span role="listitem">personne</span>
              <span role="listitem">email</span>
              <span role="listitem">org</span>
              <span role="listitem">rôle</span>
              <span role="listitem">id</span>
            </div>
          </div>
        </ArtefactCard>
      </div>
    </section>

    <section id="concrete" class="xo-shell xo-section xo-compact-section" aria-labelledby="concrete-title">
      <div class="xo-proof-layout">
        <div class="xo-proof-copy">
          <p class="xo-kicker">Cas-type réaliste</p>
          <h2 id="concrete-title" class="xo-title xo-title--section">Un contrat, cinq champs, une version relue.</h2>
          <p>
            Un prompt de synthèse de contrat contient un nom, un email, une organisation, un rôle et un identifiant.
            Paranoia les détecte, les masque, et laisse l’utilisateur décider avant l’envoi.
          </p>
        </div>
        <AgentTraceDemo
          title="paranoia/prompt-review"
          progressLabel="5 champs"
          steps={[
            { prompt: '❯', text: 'Analyser le prompt avant envoi.', dim: true },
            { text: 'Scanning...', dim: true },
            { prompt: '▸', text: 'detect personne → "Maya Hoarau"', accent: true, progress: 20 },
            { prompt: '▸', text: 'detect email → maya.hoarau@atelier-kanope.example', accent: true, progress: 40 },
            { prompt: '▸', text: 'detect org → "Atelier Kanopé"', accent: true, progress: 60 },
            { prompt: '▸', text: 'detect id → "K-47B"', accent: true, progress: 80 },
            { prompt: '▸', text: 'detect rôle → "direction ops"', accent: true, progress: 100 },
            { prompt: '✓', text: '5 champs détectés. Masquage prêt.', accent: true },
            { text: 'rule: mask before send', dim: true },
            { text: 'state: review required', dim: true },
          ]}
        />
      </div>

      <div class="xo-proof-layout" style="margin-top: 3rem;">
        <div class="xo-proof-copy">
          <p class="xo-kicker">Avant / après</p>
          <h3 class="xo-title xo-title--section" style="font-size: clamp(1.5rem, 2vw, 2rem);">Le prompt garde son intention, pas ses secrets.</h3>
          <p>
            À gauche, le prompt brut. À droite, la version relue. L’intention de travail reste intacte.
          </p>
        </div>
        <a
          class="xo-artifact-panel xo-card-shimmer"
          href="/confidentialite-prompts-ia"
          data-event="privacy_click"
          aria-label="Voir la confidentialité des prompts — avant et après masquage"
          style="padding: 0; overflow: hidden; text-decoration: none; color: inherit;"
        >
          <ChatBubbleDemo
            messages={[
              { role: 'user', text: 'Peux-tu résumer le contrat Atelier Kanopé ? Contact : Maya Hoarau, direction ops, maya.hoarau@atelier-kanope.example. Dossier fournisseur K-47B. Inclure la clause 4.2.' },
              { role: 'assistant', text: 'Peux-tu résumer le contrat [Organisation] ? Contact : [Prénom] [Nom], [Rôle], [Email]. Dossier fournisseur [Identifiant]. Inclure la clause 4.2.' },
              { role: 'user', text: 'Quelle est la politique de conservation des prompts ?' },
              { role: 'assistant', text: 'Quelle est la politique de conservation des [documents] ?' },
            ]}
          />
        </a>
      </div>
    </section>

    <section id="proof" class="xo-shell xo-section" aria-labelledby="proof-title" style="position: relative;">
      <GridShimmer count={14} style="position: absolute; inset: 0; pointer-events: none;" />
      <div class="xo-proof-layout" style="position: relative;">
        <div class="xo-proof-copy">
          <p class="xo-kicker">Preuve</p>
          <h2 id="proof-title" class="xo-title xo-title--section">Transparence documentée, pas promesse.</h2>
          <p>
            Sentry pour les crashs, Vercel Analytics pour l’usage agrégé, conservation 90 jours maximum,
            prompts non stockés côté Paranoia, suppression sur demande. Tout est nommé sur la page transparence.
          </p>
        </div>
        <a class="xo-path-card xo-card-shimmer" href="/rapports-incidents" data-event="transparency_click">
          <div class="xo-path-artifact" aria-hidden="true">
            <div><span>01</span><strong>collecte</strong></div>
            <div><span>02</span><strong>conservation</strong></div>
            <div class="is-output"><span>03</span><strong>suppression</strong></div>
          </div>
          <div>
            <p class="xo-label">Transparence</p>
            <h3>Lire le périmètre exact.</h3>
            <p>Rapports techniques, exclusions, durée de conservation, support et suppression.</p>
          </div>
          <span class="xo-card-arrow">Lire la transparence →</span>
        </a>
      </div>
    </section>

    <section id="cta" class="xo-shell xo-section" aria-labelledby="start-title">
      <div class="xo-start-paths">
        <article class="xo-start-panel">
          <div>
            <p class="xo-label">Pilote privé</p>
            <h2 id="start-title">Demander un accès pilote.</h2>
          </div>
          <p>
            Envoyez trois lignes, pas un dossier. Le premier échange sert seulement à vérifier
            si Paranoia répond au risque réel.
          </p>
          <div class="xo-contact-actions">
            <a class="xo-button xo-button--primary" href={PARANOIA_CONTACT_HREF} data-event="contact_mail_click">Demander un accès pilote</a>
            <a class="xo-button" href="/rapports-incidents" data-event="transparency_click">Voir la transparence</a>
          </div>
          <p class="pilot-hint">Email direct : <a href={PARANOIA_CONTACT_HREF}>{PARANOIA_CONTACT_EMAIL}</a>.</p>
        </article>
        <a class="xo-path-card xo-card-shimmer" href="/cas-usages" data-event="cases_click">
          <div class="xo-path-artifact" aria-hidden="true">
            <div><span>01</span><strong>contrats</strong></div>
            <div><span>02</span><strong>RH</strong></div>
            <div class="is-output"><span>03</span><strong>support</strong></div>
          </div>
          <div>
            <p class="xo-label">Cas d’usage</p>
            <h3>Vérifier sur votre flux.</h3>
            <p>Contrats, RH, support, opérations : un exemple concret par contexte.</p>
          </div>
          <span class="xo-card-arrow">Voir les cas →</span>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
