---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PARANOIA_CONTACT_HREF } from '../lib/contact';
---

<BaseLayout
  title="Page introuvable — Paranoia"
  description="Cette page n'existe pas ou plus. Reprendre par le produit ou par la page de transparence."
  noIndex={true}
>
  <main id="main" class="xo-page xo-page--product">
    <section class="xo-shell xo-hero" aria-labelledby="notfound-title">
      <div>
        <p class="xo-kicker">404</p>
        <h1 id="notfound-title" class="xo-title xo-title--wide">Cette page n'existe pas ou plus.</h1>
        <p class="xo-subtitle">
          Le lien a peut-être changé. Reprenez par le produit ou par la page de transparence.
        </p>
        <div class="xo-actions">
          <a class="xo-button xo-button--primary" href={PARANOIA_CONTACT_HREF}>Demander un accès pilote</a>
          <a class="xo-button" href="/rapports-incidents">Voir la transparence</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
