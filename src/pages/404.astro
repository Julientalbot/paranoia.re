---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page introuvable — Paranoia"
  description="Cette page n'existe pas ou plus. Reprendre par le pilote ou par les rapports d'incidents."
  canonicalPath="/404"
>
  <main id="main" class="xo-page xo-page--product">
    <section class="xo-shell xo-hero" aria-labelledby="notfound-title">
      <div>
        <p class="xo-kicker">404</p>
        <h1 id="notfound-title" class="xo-title xo-title--wide">Cette page n'existe pas ou plus.</h1>
        <p class="xo-subtitle">
          Le lien a peut-être changé. Reprenez par le pilote ou par le journal de confiance.
        </p>
        <div class="xo-actions">
          <a class="xo-button xo-button--primary" href="/#cta">Décrire un pilote</a>
          <a class="xo-button" href="/rapports-incidents">Lire les incidents</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
