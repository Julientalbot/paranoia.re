---
import BaseLayout from '../layouts/BaseLayout.astro';
import AgentTraceDemo from '../components/living-artefacts/AgentTraceDemo.astro';
import ModeTabs from '../components/sections/ModeTabs.astro';
import { PARANOIA_CONTACT_HREF } from '../lib/contact';
import HeroShimmer from '../components/living-artefacts/HeroShimmer.astro';
import HeroHeadline from '../components/living-artefacts/HeroHeadline.astro';
import GridShimmer from '../components/living-artefacts/GridShimmer.astro';

const controls = [
  {
    label: 'Périmètre',
    title: 'Avant l’envoi, pas partout.',
    body: 'Paranoia intervient sur le prompt en préparation. Il ne prétend pas contrôler tout le système d’information.',
  },
  {
    label: 'Validation',
    title: 'La personne garde la décision.',
    body: 'La relecture humaine reste obligatoire avant l’usage d’un assistant IA, surtout dans les contextes sensibles.',
  },
  {
    label: 'Traçabilité',
    title: 'La transparence est documentée.',
    body: 'La page de transparence précise ce que les rapports techniques peuvent contenir et ce qui reste exclu.',
  },
  {
    label: 'Support',
    title: 'Suppression sur demande.',
    body: 'Une équipe pilote doit pouvoir demander une suppression anticipée d’un rapport technique ou signaler un problème.',
  },
];
---

<BaseLayout
  title="Sécurité des prompts IA — Paranoia"
  description="Principes de sécurité de Paranoia : périmètre limité, relecture obligatoire, absence de DLP magique, support pilote et suppression sur demande."
  canonicalPath="/securite"
>
  <main id="main" class="xo-page xo-page--product">
    <section class="xo-shell xo-home-hero--stack" aria-labelledby="security-title">
      <div class="xo-hero-lead">
        <p class="xo-kicker">Sécurité</p>
        <HeroHeadline id="security-title" class="xo-title--wide" text="Un contrôle limité doit être très clair." />
        <HeroShimmer />
        <p class="xo-subtitle">
          La sécurité de Paranoia repose d’abord sur son périmètre : rendre visible une exposition avant l’envoi,
          garder une décision humaine, et documenter les limites.
        </p>
        <div class="xo-actions">
          <a class="xo-button xo-button--primary" href={PARANOIA_CONTACT_HREF} data-event="primary_cta_click">Demander un accès pilote</a>
          <a class="xo-button" href="/rapports-incidents" data-event="transparency_click">Voir la transparence</a>
        </div>
      </div>
    </section>

    <section class="xo-shell xo-section" aria-labelledby="controls-title">
      <div class="xo-proof-layout">
        <div class="xo-proof-copy">
          <p class="xo-kicker">Contrôles</p>
          <h2 id="controls-title" class="xo-title xo-title--section">Ce que le pilote doit rendre explicite.</h2>
          <p>Une organisation doit pouvoir comprendre le rôle du produit avant de lui confier un flux sensible.</p>
          <div class="xo-actions">
            <a class="xo-button" href={PARANOIA_CONTACT_HREF} data-event="primary_cta_click">Demander un accès pilote →</a>
          </div>
        </div>
        <AgentTraceDemo
          title="security/audit"
          progressLabel="audit"
          steps={[
            { prompt: '❯', text: 'Audit sécurité des prompts IA.', dim: true },
            { text: 'Vérification...', dim: true },
            { prompt: '▸', text: 'Stockage local: aucun prompt envoyé sans validation', dim: true },
            { prompt: '▸', text: 'Chiffrement: AES-256 en transit', dim: true },
            { text: 'Valider les contrôles', accent: true, progress: 40 },
            { prompt: '◆', text: 'Pas de télémétrie, pas de logs distants', accent: true, progress: 70 },
            { prompt: '▸', text: 'Suppression: immédiate après masquage', dim: true },
            { text: 'Audit: contrôle local, pas de fuite', accent: true, progress: 100 },
            { prompt: '✓', text: 'Conforme: local-first, privacy-bound.', accent: true },
          ]}
        />
      </div>
      <div class="xo-signal-list">
        {controls.map((item) => (
          <article class="xo-card-shimmer">
            <span>{item.label}</span>
            <strong>{item.title}</strong>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
      <ModeTabs
        artifactTitle="sécurité · 3 contrôles"
        tabs={[
          { id: 'stockage', label: 'Stockage', content: 'Local uniquement\nAucun prompt envoyé sans validation\nSuppression immédiate post-masquage' },
          { id: 'transit', label: 'Transit', content: 'Chiffrement AES-256\nPas de télémétrie\nPas de logs distants\nPas de cookies tiers' },
          { id: 'acces', label: 'Accès', content: 'Contrôle local utilisateur\nPas de compte requis\nPas d\'API distante\nDonnées jamais hors du poste' },
        ]}
      />
    </section>

    <section class="xo-shell xo-section" aria-labelledby="security-cta" style="position: relative;">
      <GridShimmer count={14} style="position: absolute; inset: 0; pointer-events: none;" />
      <div class="xo-start-paths" style="position: relative;">
        <article class="xo-start-panel">
          <div>
            <p class="xo-label">Pilote privé</p>
            <h2 id="security-cta">Vérifier le périmètre sur votre flux.</h2>
          </div>
          <p>
            Le pilote sert à confirmer que le périmètre de Paranoia correspond à votre risque réel.
            Trois lignes suffisent : l’assistant utilisé, les contenus copiés, la limite à garder visible.
          </p>
          <div class="xo-contact-actions">
            <a class="xo-button xo-button--primary" href={PARANOIA_CONTACT_HREF} data-event="contact_mail_click">Demander un accès pilote</a>
            <a class="xo-button" href="/confidentialite-prompts-ia" data-event="privacy_click">Voir la confidentialité</a>
          </div>
        </article>
        <a class="xo-path-card xo-card-shimmer" href="/rapports-incidents" data-event="transparency_click">
          <div class="xo-path-artifact" aria-hidden="true">
            <div><span>01</span><strong>collecte</strong></div>
            <div><span>02</span><strong>conservation</strong></div>
            <div class="is-output"><span>03</span><strong>suppression</strong></div>
          </div>
          <div>
            <p class="xo-label">Transparence</p>
            <h3>Ce qui est envoyé, ce qui ne l’est pas.</h3>
            <p>Rapports techniques, exclusions, durée de conservation et support documentés publiquement.</p>
          </div>
          <span class="xo-card-arrow">Lire la transparence →</span>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
