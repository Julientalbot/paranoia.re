---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import { PARANOIA_CONTACT_EMAIL, PARANOIA_CONTACT_HREF } from '../lib/contact';
---

<BaseLayout
  title="Rapports d'incidents (Sentry) — Paranoia"
  description="Transparence sur les rapports d'erreurs : Sentry, protection des données personnelles, signalement manuel optionnel, conservation 90 jours."
  canonicalPath="/rapports-incidents"
>
  <main class="xo-page xo-page--product">
    <Header ctaHref="/#cta" ctaLabel="Beta privée en cours" />

    <section class="xo-shell xo-hero xo-hero--split" aria-labelledby="incidents-title">
      <div>
        <p class="xo-kicker">Transparence</p>
        <h1 id="incidents-title" class="xo-title xo-title--wide">Rapports d'incidents Sentry.</h1>
        <p class="xo-subtitle">
          Pour améliorer la stabilité de Paranoia, Sentry peut recevoir des rapports techniques d'erreur.
          L'objectif est de diagnostiquer les crashs et bugs sans collecter les contenus de prompts.
        </p>
        <div class="xo-actions">
          <a class="xo-button xo-button--primary" href={PARANOIA_CONTACT_HREF}>Contacter le support</a>
          <a class="xo-button" href="/#cta">Rejoindre la beta</a>
        </div>
      </div>

      <aside class="xo-artifact-panel paranoia-trust-artifact" aria-label="Ledger des rapports d'incidents">
        <div class="xo-console-top">
          <span class="xo-console-dot"></span>
          <span class="xo-console-dot"></span>
          <span class="xo-console-dot"></span>
          <strong>trust/incidents</strong>
        </div>
        <div class="paranoia-trust-ledger">
          <div><span>finalité</span><strong>diagnostic bugs + stabilité</strong></div>
          <div><span>contenu prompt</span><strong>non collecté par défaut</strong></div>
          <div><span>conservation</span><strong>90 jours maximum</strong></div>
          <div><span>signalement</span><strong>manuel, contexte choisi</strong></div>
        </div>
        <p>
          La confiance est traitée comme une surface lisible : données envoyées, protections, sessions, support et limites.
        </p>
      </aside>
    </section>

    <section class="xo-shell xo-section" aria-label="Périmètre des rapports">
      <div class="xo-signal-list">
        <article>
          <span>Automatique</span>
          <strong>Crashs et erreurs.</strong>
          <p>Message d'erreur, trace technique, version, navigateur, OS, langue, horodatage et identifiant d'événement.</p>
        </article>
        <article>
          <span>Protection</span>
          <strong>Champs sensibles masqués.</strong>
          <p>Sentry est configuré pour supprimer ou masquer emails, noms, identifiants, tokens, clés et secrets si présents.</p>
        </article>
        <article>
          <span>Sessions</span>
          <strong>Stabilité par version.</strong>
          <p>Des événements de session peuvent mesurer la stabilité et l'impact des versions, sans prompts, textes, pages consultées ni URL.</p>
        </article>
        <article>
          <span>Optionnel</span>
          <strong>Signalement manuel.</strong>
          <p>Un rapport volontaire peut ajouter du contexte choisi par l'utilisateur. Évitez d’inclure données client ou secrets.</p>
        </article>
      </div>
    </section>

    <section class="xo-shell xo-section">
      <div class="xo-start-paths">
        <article class="xo-start-panel">
          <div>
            <p class="xo-label">Questions</p>
            <h2>Ce qui est envoyé.</h2>
          </div>
          <p>
            Par défaut, Paranoia est conçu pour fonctionner en local. Les envois automatiques concernent les rapports
            techniques et les événements de stabilité, pas les contenus de prompts.
          </p>
        </article>
        <a class="xo-start-card" href={PARANOIA_CONTACT_HREF}>
          <div>
            <p class="xo-label">Support</p>
            <h2>Demander une suppression ou signaler un problème.</h2>
          </div>
          <p>Écrivez à {PARANOIA_CONTACT_EMAIL} pour une question ou une demande de suppression anticipée d'un rapport.</p>
          <span class="xo-card-arrow">Contacter →</span>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
