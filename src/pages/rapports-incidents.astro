---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PARANOIA_CONTACT_EMAIL, PARANOIA_CONTACT_HREF } from '../lib/contact';
import HeroShimmer from '../components/living-artefacts/HeroShimmer.astro';

const reportItems = [
  {
    label: 'Rapports techniques',
    title: 'Crashs et erreurs.',
    body: "Message d'erreur, trace technique, version, navigateur, OS, langue, horodatage et identifiant d'événement.",
  },
  {
    label: 'Protection',
    title: 'Champs sensibles masqués.',
    body: 'Sentry est configuré pour supprimer ou masquer emails, noms, identifiants, tokens, clés et secrets si présents.',
  },
  {
    label: 'Sessions',
    title: 'Stabilité par version.',
    body: "Des événements de session peuvent mesurer la stabilité sans prompts, textes, pages consultées ni URL.",
  },
  {
    label: 'Manuel',
    title: 'Contexte choisi par l’utilisateur.',
    body: "Un signalement volontaire peut ajouter du contexte. Il ne faut pas y inclure données client, prompts sensibles ou secrets.",
  },
];
---

<BaseLayout
  title="Transparence prompts IA — Paranoia"
  description="Ce que Paranoia envoie, ce qu'il n'envoie pas, combien de temps les rapports techniques sont conservés et comment contacter le support."
  canonicalPath="/rapports-incidents"
>
  <main id="main" class="xo-page xo-page--product">
    <section class="xo-shell xo-hero xo-hero--split" aria-labelledby="incidents-title">
      <div>
        <p class="xo-kicker">Transparence</p>
        <h1 id="incidents-title" class="xo-title xo-title--wide">Ce qui est envoyé. Ce qui ne l’est pas.</h1>
        <HeroShimmer />
        <p class="xo-subtitle">
          Paranoia peut utiliser Sentry pour diagnostiquer les bugs et la stabilité du pilote.
          Les rapports automatiques concernent le fonctionnement technique, pas le contenu des prompts.
          Vercel Analytics et Speed Insights mesurent l’usage agrégé du site, sans collecter le texte des prompts.
        </p>
        <div class="xo-actions">
          <a class="xo-button xo-button--primary" href={PARANOIA_CONTACT_HREF} data-event="support_mail_click">Contacter le support</a>
          <a class="xo-button" href="/#concrete" data-event="product_click">Retour au produit</a>
        </div>
      </div>

      <aside class="xo-artifact-panel paranoia-trust-artifact xo-card-shimmer" aria-label="Ledger de transparence Paranoia">
        <div class="xo-console-top">
          <span class="xo-console-dot"></span>
          <span class="xo-console-dot"></span>
          <span class="xo-console-dot"></span>
          <strong>trust/telemetry</strong>
        </div>
        <div class="paranoia-trust-ledger">
          <div><span>finalité</span><strong>bugs + stabilité</strong></div>
          <div><span>prompts</span><strong>non stockés côté Paranoia</strong></div>
          <div><span>conservation</span><strong>90 jours maximum</strong></div>
          <div><span>support</span><strong>suppression sur demande</strong></div>
        </div>
        <p>
          La page sert de trace publique : collecte technique, exclusions, durée de conservation, support et suppression.
        </p>
      </aside>
    </section>

    <section class="xo-shell xo-section" aria-labelledby="reports-title">
      <div class="xo-section-heading">
        <div>
          <p class="xo-kicker">Rapports techniques</p>
          <h2 id="reports-title" class="xo-title xo-title--section">Le périmètre reste étroit.</h2>
        </div>
        <p>Le suivi sert à corriger le produit pilote, pas à inspecter les prompts des utilisateurs.</p>
      </div>
      <div class="xo-signal-list">
        {reportItems.map((item) => (
          <article class="xo-card-shimmer">
            <span>{item.label}</span>
            <strong>{item.title}</strong>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="xo-shell xo-section" aria-labelledby="incidents-cta">
      <div class="xo-start-paths">
        <article class="xo-start-panel">
          <div>
            <p class="xo-label">Support</p>
            <h2 id="incidents-cta">Demander une suppression ou signaler un problème.</h2>
          </div>
          <p>
            Écrivez à {PARANOIA_CONTACT_EMAIL} pour une question, un signalement de bug
            ou une demande de suppression anticipée d’un rapport technique.
          </p>
          <div class="xo-contact-actions">
            <a class="xo-button xo-button--primary" href={PARANOIA_CONTACT_HREF} data-event="support_mail_click">Contacter le support</a>
            <a class="xo-button" href="/securite" data-event="security_click">Voir la sécurité</a>
          </div>
        </article>
        <a class="xo-path-card xo-card-shimmer" href="/securite" data-event="security_click">
          <div class="xo-path-artifact" aria-hidden="true">
            <div><span>01</span><strong>périmètre</strong></div>
            <div><span>02</span><strong>relecture</strong></div>
            <div class="is-output"><span>03</span><strong>limites</strong></div>
          </div>
          <div>
            <p class="xo-label">Sécurité</p>
            <h3>Un contrôle limité, documenté.</h3>
            <p>Le périmètre, la relecture obligatoire et les limites du produit sont explicites.</p>
          </div>
          <span class="xo-card-arrow">Voir la sécurité →</span>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
