---
import BaseLayout from '../layouts/BaseLayout.astro';
import ModeTabs from '../components/sections/ModeTabs.astro';
import AgentTraceDemo from '../components/living-artefacts/AgentTraceDemo.astro';
import { PARANOIA_CONTACT_HREF } from '../lib/contact';
import HeroHeadline from '../components/living-artefacts/HeroHeadline.astro';

import GridShimmer from '../components/living-artefacts/GridShimmer.astro';

const detectionSteps = [
  { prompt: '❯', text: 'Analyser prompt avant envoi.', dim: true },
  { text: 'Scanning...', dim: true },
  { prompt: '▸', text: 'detect: "Maya Hoarau" (personne)', accent: true, progress: 20 },
  { prompt: '▸', text: 'detect: maya.hoarau@atelier-kanope.example (email)', accent: true, progress: 40 },
  { prompt: '▸', text: 'detect: "Atelier Kanopé" (organisation)', accent: true, progress: 60 },
  { prompt: '▸', text: 'detect: "K-47B" (identifiant)', accent: true, progress: 80 },
  { prompt: '▸', text: 'detect: "direction ops" (rôle)', accent: true, progress: 100 },
  { prompt: '✓', text: '5 champs détectés. Masquage prêt.', accent: true },
  { text: 'rule: mask before send', dim: true },
];
---

<BaseLayout
  title="Cas d’usage prompts IA — Paranoia"
  description="Cas d’usage de Paranoia pour contrats, RH, support et opérations quand des données sensibles risquent d’être copiées dans un prompt."
  canonicalPath="/cas-usages"
>
  <main id="main" class="xo-page xo-page--product">
    <section class="xo-shell xo-home-hero xo-home-hero--stack" aria-labelledby="cases-title">
      <div class="xo-hero-lead">
        <p class="xo-kicker">Cas d’usage</p>
        <HeroHeadline
          id="cases-title"
          class="xo-title--wide"
          text="Quand le prompt contient trop de réel."
        />
        <p class="xo-subtitle">
          Paranoia sert aux moments où le travail est utile à l’assistant IA, mais où noms,
          contacts, identifiants ou éléments de dossier doivent être revus avant l’envoi.
        </p>
        <div class="xo-actions">
          <a class="xo-button xo-button--primary" href={PARANOIA_CONTACT_HREF} data-event="primary_cta_click">Demander un accès pilote</a>
          <a class="xo-button" href="/rapports-incidents" data-event="transparency_click">Voir la transparence</a>
        </div>
      </div>

    </section>

    <section class="xo-shell xo-section" aria-labelledby="concrete-title">
      <div class="xo-proof-layout">
        <div class="xo-proof-copy">
          <p class="xo-kicker">Exemple réel</p>
          <h2 id="concrete-title" class="xo-title xo-title--section">Synthèse de contrat — Atelier Kanopé.</h2>
          <p>
            Un collaborateur colle un contrat client dans un assistant IA pour en obtenir un résumé.
            Le prompt brut transporte un nom, un email, une organisation, un rôle et un identifiant fournisseur.
            La version relue garde la demande, remplace les données directes par des libellés contrôlables,
            et part vers l’assistant sans exposer le client.
          </p>
        </div>
        <AgentTraceDemo
          title="prompt-review/contrat"
          progressLabel="détection"
          steps={detectionSteps}
        />
      </div>

      <ModeTabs
        artifactTitle="cas-usage · prompt-review"
        tabs={[
          { id: 'contrat', label: 'Contrat', content: 'Avant :\nPeux-tu résumer le contrat Atelier Kanopé ? Contact : Maya Hoarau, direction ops, maya.hoarau@atelier-kanope.example.\n\nAprès :\nPeux-tu résumer le contrat [Organisation] ? Contact : [Prénom] [Nom], [Rôle], [Email].' },
          { id: 'rh', label: 'RH', content: 'Avant :\nPrépare un courrier pour Marie Dubois, salariée n°1042, adresse 12 rue des Lilas.\n\nAprès :\nPrépare un courrier pour [Nom salarié], n°[ID], [Adresse].' },
          { id: 'support', label: 'Support', content: 'Avant :\nLe client Acme Corp (SIRET 12345678900012) signale un bug sur la facture FAC-2026-0042.\n\nAprès :\nLe client [Organisation] (SIRET [ID]) signale un bug sur la facture [ID].' },
        ]}
      />
    </section>

    <section class="xo-shell xo-section" aria-labelledby="proof-title" style="position: relative;">
      <GridShimmer count={14} style="position: absolute; inset: 0; pointer-events: none;" />
      <div class="xo-proof-layout" style="position: relative;">
        <div class="xo-proof-copy">
          <p class="xo-kicker">Preuve</p>
          <h2 id="proof-title" class="xo-title xo-title--section">Ce qui part, ce qui reste, nommés.</h2>
          <p>
            Les rapports techniques documentent crashs et stabilité, pas le contenu des prompts.
            Sentry masque emails, noms, tokens et secrets. Conservation 90 jours maximum,
            suppression sur demande. Le périmètre est public.
          </p>
        </div>
        <a class="xo-path-card xo-card-shimmer" href="/rapports-incidents" data-event="transparency_click">
          <div class="xo-path-artifact" aria-hidden="true">
            <div><span>01</span><strong>collecte</strong></div>
            <div><span>02</span><strong>conservation</strong></div>
            <div class="is-output"><span>03</span><strong>suppression</strong></div>
          </div>
          <div>
            <p class="xo-label">Transparence</p>
            <h3>Lire le périmètre exact.</h3>
            <p>Rapports techniques, exclusions, durée de conservation et support.</p>
          </div>
          <span class="xo-card-arrow">Lire la transparence →</span>
        </a>
      </div>
    </section>

    <section class="xo-shell xo-section" aria-labelledby="cases-cta">
      <div class="xo-start-paths">
        <article class="xo-start-panel">
          <div>
            <p class="xo-label">Pilote privé</p>
            <h2 id="cases-cta">Vérifier Paranoia sur votre cas.</h2>
          </div>
          <p>
            Si votre flux ressemble à cet exemple, le pilote sert à le vérifier sur un cas réel.
            Trois lignes suffisent : l’assistant utilisé, les contenus copiés, la limite à garder visible.
          </p>
          <div class="xo-contact-actions">
            <a class="xo-button xo-button--primary" href={PARANOIA_CONTACT_HREF} data-event="contact_mail_click">Demander un accès pilote</a>
            <a class="xo-button" href="/confidentialite-prompts-ia" data-event="privacy_click">Voir la confidentialité</a>
          </div>
        </article>
        <a class="xo-path-card xo-card-shimmer" href="/rapports-incidents" data-event="transparency_click">
          <div class="xo-path-artifact" aria-hidden="true">
            <div><span>01</span><strong>collecte</strong></div>
            <div><span>02</span><strong>conservation</strong></div>
            <div class="is-output"><span>03</span><strong>suppression</strong></div>
          </div>
          <div>
            <p class="xo-label">Transparence</p>
            <h3>Ce qui est envoyé, ce qui ne l’est pas.</h3>
            <p>Rapports techniques, prompts, conservation, support et suppression documentés.</p>
          </div>
          <span class="xo-card-arrow">Lire la transparence →</span>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
