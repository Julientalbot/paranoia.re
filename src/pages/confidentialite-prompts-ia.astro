---
import BaseLayout from '../layouts/BaseLayout.astro';
import AgentTraceDemo from '../components/living-artefacts/AgentTraceDemo.astro';
import ModeTabs from '../components/sections/ModeTabs.astro';
import { PARANOIA_CONTACT_HREF } from '../lib/contact';


const exposureFlow = [
  ['01', 'Prompt', 'texte + contexte'],
  ['02', 'Détection', 'champs repérables'],
  ['03', 'Masquage', 'libellés contrôlables'],
  ['04', 'Relecture', 'corriger ou retirer'],
  ['05', 'Envoi', 'décision humaine'],
];
---

<BaseLayout
  title="Confidentialité prompts IA — Paranoia"
  description="Comprendre comment Paranoia réduit l’exposition des prompts IA : détection, masquage, relecture humaine, limites et données à garder hors assistant."
  canonicalPath="/confidentialite-prompts-ia"
>
  <main id="main" class="xo-page xo-page--product">
    <section class="xo-shell xo-hero xo-hero--split" aria-labelledby="privacy-title">
      <div>
        <p class="xo-kicker">Confidentialité des prompts IA</p>
        <h1 id="privacy-title" class="xo-title xo-title--wide">Réduire l’exposition ne suffit pas toujours.</h1>
        <p class="xo-subtitle">
          Paranoia aide à préparer un prompt plus contrôlable. La règle reste simple :
          ce qui ne doit pas sortir ne doit pas être envoyé, même masqué.
        </p>
        <div class="xo-actions">
          <a class="xo-button xo-button--primary" href={PARANOIA_CONTACT_HREF} data-event="primary_cta_click">Demander un accès pilote</a>
          <a class="xo-button" href="/securite" data-event="security_click">Voir la sécurité</a>
        </div>
      </div>

      <a class="xo-card-shimmer" href={PARANOIA_CONTACT_HREF} aria-label="Demander un accès pilote">
        <AgentTraceDemo
          title="privacy/controls"
          progressLabel="contrôles"
          steps={[
            { prompt: '❯', text: 'Vérifier les contrôles confidentialité.', dim: true },
            { text: 'Inspection...', dim: true },
            { prompt: '▸', text: 'Données personnelles: masquées avant envoi', dim: true },
            { prompt: '▸', text: 'Secrets: non transmis (blocage)', dim: true },
            { text: 'Frontières respectées', accent: true, progress: 50 },
            { prompt: '◆', text: 'Aucune donnée client stockée', accent: true, progress: 75 },
            { prompt: '▸', text: 'Suppression: immédiate post-masquage', dim: true },
            { text: 'Confidentialité: local, éphémère, borné', accent: true, progress: 100 },
            { prompt: '✓', text: 'Contrôles actifs. Pas de fuite.', accent: true },
          ]}
        />
      </a>
    </section>

    <section class="xo-shell xo-section" aria-labelledby="concrete-title">
      <div class="xo-proof-layout">
        <div class="xo-proof-copy">
          <p class="xo-kicker">Exemple réel</p>
          <h2 id="concrete-title" class="xo-title xo-title--section">Un prompt traverse cinq états.</h2>
          <p>
            Du texte brut à la décision humaine, chaque étape est nommée et inspectable.
            Le masquage n’autorise jamais l’envoi : la relecture décide.
          </p>
        </div>
        <div class="paranoia-exposure-map xo-artifact-panel" aria-label="Carte d'exposition d'un prompt avant assistant IA">
          <div class="paranoia-exposure-map__header">
            <span>surface d’exposition</span>
            <strong>Ce qui sort doit être décidé, pas seulement masqué.</strong>
          </div>
          <div class="paranoia-exposure-map__chain" role="list">
            {exposureFlow.map(([step, label, body], index) => (
              <div class:list={['paranoia-exposure-map__node', index === exposureFlow.length - 1 && 'is-output']} role="listitem">
                <span>{step}</span>
                <strong>{label}</strong>
                <p>{body}</p>
              </div>
            ))}
          </div>
          <div class="paranoia-exposure-map__rule">
            <span>limite</span>
            <strong>secret, contrat, client sensible : rester hors assistant</strong>
          </div>
        </div>
      </div>
      <ModeTabs
        artifactTitle="confidentialité · 3 frontières"
        tabs={[
          { id: 'donnees', label: 'Données', content: 'Noms, emails, organisations: masqués\nIdentifiants: masqués\nSecrets: bloqués (pas masqués)' },
          { id: 'session', label: 'Session', content: 'Pas de dump de session\nPas de messages privés\nPas de chemins locaux complets\nMétadonnées uniquement' },
          { id: 'suppression', label: 'Suppression', content: 'Suppression immédiate post-masquage\nPas de conservation locale\nPas d\'historique des prompts\nTrace: métadonnée seulement' },
        ]}
      />
    </section>

    <section class="xo-shell xo-section" aria-labelledby="proof-title">
      <div class="xo-proof-layout">
        <div class="xo-proof-copy">
          <p class="xo-kicker">Preuve</p>
          <h2 id="proof-title" class="xo-title xo-title--section">Les limites sont nommées publiquement.</h2>
          <p>
            Sentry masque emails, noms, tokens et secrets. Conservation 90 jours maximum.
            Prompts non stockés côté Paranoia. Suppression sur demande.
            Le périmètre est documenté, pas promis.
          </p>
        </div>
        <a class="xo-path-card xo-card-shimmer" href="/rapports-incidents" data-event="transparency_click">
          <div class="xo-path-artifact" aria-hidden="true">
            <div><span>01</span><strong>collecte</strong></div>
            <div><span>02</span><strong>conservation</strong></div>
            <div class="is-output"><span>03</span><strong>suppression</strong></div>
          </div>
          <div>
            <p class="xo-label">Transparence</p>
            <h3>Lire le périmètre exact.</h3>
            <p>Rapports techniques, exclusions, durée de conservation et support.</p>
          </div>
          <span class="xo-card-arrow">Lire la transparence →</span>
        </a>
      </div>
    </section>

    <section class="xo-shell xo-section" aria-labelledby="privacy-cta">
      <div class="xo-start-paths">
        <article class="xo-start-panel">
          <div>
            <p class="xo-label">Pilote privé</p>
            <h2 id="privacy-cta">Tester le contrôle avant l’envoi.</h2>
          </div>
          <p>
            Le pilote sert à vérifier si ce contrôle répond à votre risque réel.
            Trois lignes suffisent : l’assistant utilisé, les contenus copiés, la limite à garder visible.
          </p>
          <div class="xo-contact-actions">
            <a class="xo-button xo-button--primary" href={PARANOIA_CONTACT_HREF} data-event="contact_mail_click">Demander un accès pilote</a>
            <a class="xo-button" href="/securite" data-event="security_click">Voir la sécurité</a>
          </div>
        </article>
        <a class="xo-path-card xo-card-shimmer" href="/securite" data-event="security_click">
          <div class="xo-path-artifact" aria-hidden="true">
            <div><span>01</span><strong>périmètre</strong></div>
            <div><span>02</span><strong>relecture</strong></div>
            <div class="is-output"><span>03</span><strong>limites</strong></div>
          </div>
          <div>
            <p class="xo-label">Sécurité</p>
            <h3>Un contrôle limité, documenté.</h3>
            <p>Le périmètre, la relecture obligatoire et les limites du produit sont explicites.</p>
          </div>
          <span class="xo-card-arrow">Voir la sécurité →</span>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
