---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PARANOIA_CONTACT_HREF } from '../lib/contact';

const exposureFlow = [
  ['01', 'Prompt', 'texte + contexte'],
  ['02', 'Détection', 'champs repérables'],
  ['03', 'Masquage', 'libellés contrôlables'],
  ['04', 'Relecture', 'corriger ou retirer'],
  ['05', 'Envoi', 'décision humaine'],
];

const faqItems = [
  {
    q: 'Le masquage suffit-il pour tout envoyer ?',
    a: 'Non. Le masquage réduit une exposition, mais ne remplace pas une règle de confidentialité, une obligation contractuelle ou une interdiction de sortie.',
  },
  {
    q: 'Pourquoi garder une relecture humaine ?',
    a: 'Parce que le contexte décide souvent du risque. L’utilisateur doit pouvoir corriger un masque, retirer un détail ou abandonner l’envoi.',
  },
  {
    q: 'Que faut-il garder hors assistant ?',
    a: 'Secrets, données interdites par contrat, informations dont la sortie n’a pas de base claire, et tout élément que l’organisation a explicitement exclu.',
  },
];

const faqSchema = {
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---

<BaseLayout
  title="Confidentialité prompts IA — Paranoia"
  description="Comprendre comment Paranoia réduit l’exposition des prompts IA : détection, masquage, relecture humaine, limites et données à garder hors assistant."
  canonicalPath="/confidentialite-prompts-ia"
  structuredData={faqSchema}
>
  <main id="main" class="xo-page xo-page--product">
    <section class="xo-shell xo-hero xo-hero--split" aria-labelledby="privacy-title">
      <div>
        <p class="xo-kicker">Confidentialité des prompts IA</p>
        <h1 id="privacy-title" class="xo-title xo-title--wide">Réduire l’exposition ne suffit pas toujours.</h1>
        <p class="xo-subtitle">
          Paranoia aide à préparer un prompt plus contrôlable. La règle reste simple :
          ce qui ne doit pas sortir ne doit pas être envoyé, même masqué.
        </p>
        <div class="xo-actions">
          <a class="xo-button xo-button--primary" href={PARANOIA_CONTACT_HREF}>Demander un accès pilote</a>
          <a class="xo-button" href="/securite">Voir la sécurité</a>
        </div>
      </div>

      <aside class="xo-artifact-panel" aria-label="Principes de confidentialité des prompts IA">
        <div class="xo-console-top">
          <span class="xo-console-dot"></span>
          <span class="xo-console-dot"></span>
          <span class="xo-console-dot"></span>
          <strong>privacy/prompt-control</strong>
        </div>
        <div class="xo-ledger xo-ledger--flush">
          <div><span>champ</span><strong>personne, email, organisation</strong></div>
          <div><span>action</span><strong>masque contrôlable</strong></div>
          <div><span>limite</span><strong>pas une autorisation d’envoi</strong></div>
          <div class="is-output"><span>décision</span><strong>relire ou retirer</strong></div>
        </div>
      </aside>
    </section>

    <section class="xo-shell xo-section" aria-labelledby="principles-title">
      <div class="xo-proof-layout">
        <div class="xo-proof-copy">
          <p class="xo-kicker">Méthode</p>
          <h2 id="principles-title" class="xo-title xo-title--section">Quatre gestes avant l’assistant.</h2>
          <p>Le contrôle est volontairement court : voir l’exposition, réduire ce qui peut l’être, puis décider.</p>
        </div>
        <div class="paranoia-exposure-map" aria-label="Carte d'exposition d'un prompt avant assistant IA">
          <div class="paranoia-exposure-map__header">
            <span>surface d’exposition</span>
            <strong>Ce qui sort doit être décidé, pas seulement masqué.</strong>
          </div>
          <div class="paranoia-exposure-map__chain" role="list">
            {exposureFlow.map(([step, label, body], index) => (
              <div class:list={['paranoia-exposure-map__node', index === exposureFlow.length - 1 && 'is-output']} role="listitem">
                <span>{step}</span>
                <strong>{label}</strong>
                <p>{body}</p>
              </div>
            ))}
          </div>
          <div class="paranoia-exposure-map__rule">
            <span>limite</span>
            <strong>secret, contrat, client sensible : rester hors assistant</strong>
          </div>
        </div>
      </div>
    </section>

    <section class="xo-shell xo-section" aria-labelledby="privacy-faq">
      <div class="xo-section-heading">
        <div>
          <p class="xo-kicker">Limites</p>
          <h2 id="privacy-faq" class="xo-title xo-title--section">Les limites font partie de la confidentialité.</h2>
        </div>
        <p>Une page crédible doit dire ce que le produit ne remplace pas.</p>
      </div>
      <div class="xo-signal-list">
        {faqItems.map((item) => (
          <article>
            <span>{item.q}</span>
            <strong>{item.a}</strong>
          </article>
        ))}
      </div>
    </section>

    <section class="xo-shell xo-section" aria-labelledby="privacy-cta">
      <div class="xo-start-paths">
        <article class="xo-start-panel">
          <div>
            <p class="xo-label">Pilote privé</p>
            <h2 id="privacy-cta">Tester le contrôle avant l’envoi.</h2>
          </div>
          <p>
            Le pilote sert à vérifier si ce contrôle répond à votre risque réel.
            Trois lignes suffisent : l’assistant utilisé, les contenus copiés, la limite à garder visible.
          </p>
          <div class="xo-contact-actions">
            <a class="xo-button xo-button--primary" href={PARANOIA_CONTACT_HREF} data-event="contact_mail_click">Demander un accès pilote</a>
          </div>
        </article>
        <a class="xo-path-card" href="/securite">
          <div class="xo-path-artifact" aria-hidden="true">
            <div><span>01</span><strong>périmètre</strong></div>
            <div><span>02</span><strong>relecture</strong></div>
            <div class="is-output"><span>03</span><strong>limites</strong></div>
          </div>
          <div>
            <p class="xo-label">Sécurité</p>
            <h3>Un contrôle limité, documenté.</h3>
            <p>Le périmètre, la relecture obligatoire et les limites du produit sont explicites.</p>
          </div>
          <span class="xo-card-arrow">Voir la sécurité →</span>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
