---
import '@fontsource-variable/geist';
import '@fontsource-variable/geist-mono';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import '../styles/global.css';
import '../styles/x-operational-system.css';
import Header from '../components/Header.astro';
import { PARANOIA_CONTACT_EMAIL, PARANOIA_CONTACT_HREF } from '../lib/contact';

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  image?: string;
  ogImage?: string;
  twitterImage?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  headerCtaHref?: string;
  headerCtaLabel?: string;
  noIndex?: boolean;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const DEFAULT_OG_IMAGE = '/social/linkedin-share.png';
const DEFAULT_TWITTER_IMAGE = '/social/x-card.png';

const {
  title,
  description = "Paranoia aide les équipes à réduire l'exposition de données sensibles dans leurs prompts IA avant envoi.",
  canonicalPath = Astro.url.pathname,
  image,
  ogImage,
  twitterImage,
  ogImageWidth = 1200,
  ogImageHeight,
  headerCtaHref = PARANOIA_CONTACT_HREF,
  headerCtaLabel = 'Demander un accès pilote',
  noIndex = false,
  structuredData = [],
} = Astro.props;

const canonicalUrl = new URL(canonicalPath, 'https://paranoia.re').toString();
const resolvedOgImage = ogImage ?? image ?? DEFAULT_OG_IMAGE;
const resolvedTwitterImage = twitterImage ?? image ?? DEFAULT_TWITTER_IMAGE;
const resolvedOgImageHeight = ogImageHeight ?? (resolvedOgImage === DEFAULT_OG_IMAGE ? 627 : 630);
const ogImageUrl = new URL(resolvedOgImage, 'https://paranoia.re').toString();
const twitterImageUrl = new URL(resolvedTwitterImage, 'https://paranoia.re').toString();
const structuredDataItems = Array.isArray(structuredData) ? structuredData : [structuredData];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': 'https://paranoia.re/#website',
      name: 'Paranoia',
      url: 'https://paranoia.re',
      inLanguage: 'fr-FR',
      publisher: { '@id': 'https://paranoia.re/#org' },
    },
    {
      '@type': 'SoftwareApplication',
      '@id': 'https://paranoia.re/#software',
      name: 'Paranoia',
      applicationCategory: 'SecurityApplication',
      operatingSystem: 'Web',
      url: 'https://paranoia.re',
      description:
        "Paranoia aide les équipes à réduire l'exposition de données sensibles dans leurs prompts IA avant envoi.",
      inLanguage: 'fr',
      publisher: { '@id': 'https://paranoia.re/#org' },
    },
    {
      '@type': 'WebPage',
      '@id': `${canonicalUrl}#webpage`,
      url: canonicalUrl,
      name: title,
      description,
      inLanguage: 'fr-FR',
      isPartOf: { '@id': 'https://paranoia.re/#website' },
      about: { '@id': 'https://paranoia.re/#software' },
    },
    {
      '@type': 'Organization',
      '@id': 'https://paranoia.re/#org',
      name: 'Paranoia',
      url: 'https://paranoia.re',
      sameAs: ['https://julientalbot.com'],
    },
    ...structuredDataItems,
  ],
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      (() => {
        try {
          const theme = window.localStorage.getItem('ecosystem-theme');
          if (theme === 'light' || theme === 'dark') document.documentElement.dataset.theme = theme;
        } catch (_) {
          /* Ignore storage restrictions. */
        }
      })();
    </script>

    <!-- General Sans — self-hosted (woff2 variable, @font-face dans le kernel). -->


    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="color-scheme" content="dark light" />
    {noIndex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <link rel="canonical" href={canonicalUrl} />
    )}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.png" type="image/png" sizes="512x512" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content={ogImageWidth} />
    <meta property="og:image:height" content={resolvedOgImageHeight} />
    <meta property="og:image:alt" content="Paranoia - Réduire l'exposition avant l'envoi" />
    <meta property="og:site_name" content="Paranoia" />
    <meta property="og:locale" content="fr_FR" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={twitterImageUrl} />
    <meta name="twitter:image:alt" content="Paranoia - Réduire l'exposition avant l'envoi" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="xds-theme xo-page xo-page--product">
    <a class="xo-skip-link" href="#main">Aller au contenu</a>
    <div class="app-shell">
      <Header ctaHref={headerCtaHref} ctaLabel={headerCtaLabel} />
      <slot />
      <footer class="xo-trust-footer product-footer">
        <div class="xo-shell xo-trust-grid">
          <div>
            <p class="xo-footer-brand">Paranoia</p>
            <p>Produit pilote pour inspecter, masquer et relire les prompts IA sensibles avant envoi.</p>
          </div>
          <nav aria-label="Produit">
            <h3>Produit</h3>
            <a href="/#workflow">Fonctionnement</a>
            <a href="/cas-usages">Cas d’usage</a>
            <a href="/confidentialite-prompts-ia">Confidentialité prompts</a>
            <a href="/securite">Sécurité</a>
            <a href="/#limits">Limites</a>
            <a href="/#fit">Pour qui</a>
          </nav>
          <nav aria-label="Transparence">
            <h3>Transparence</h3>
            <a href="/rapports-incidents">Ce qui est envoyé</a>
            <a href={PARANOIA_CONTACT_HREF} data-event="contact_mail_click">Support pilote</a>
          </nav>
          <nav aria-label="Liens">
            <h3>Liens</h3>
            <a href="https://julientalbot.com/">Julien Talbot</a>
          </nav>
        </div>
      </footer>
    </div>
    <Analytics />
    <SpeedInsights />
    <script is:inline>
      const ecosystemRuntime = (() => {
        const themeKey = 'ecosystem-theme';
        const root = document.documentElement;
        const lightQuery = window.matchMedia('(prefers-color-scheme: light)');

        const storedTheme = () => {
          try {
            const value = window.localStorage.getItem(themeKey);
            return value === 'light' || value === 'dark' ? value : null;
          } catch (_) {
            return null;
          }
        };

        const currentTheme = () => root.dataset.theme || (lightQuery.matches ? 'light' : 'dark');

        const syncThemeButtons = () => {
          const theme = currentTheme();
          document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
            button.dataset.themeState = theme;
            button.setAttribute(
              'aria-label',
              theme === 'dark' ? 'Passer en mode clair' : 'Passer en mode sombre',
            );
          });
        };

        const setTheme = (theme, persist = true) => {
          root.dataset.theme = theme;
          if (persist) {
            try {
              window.localStorage.setItem(themeKey, theme);
            } catch (_) {
              /* Ignore storage restrictions. */
            }
          }
          syncThemeButtons();
        };

        const setCodePanel = (artifact, id) => {
          artifact.querySelectorAll('[data-code-tab]').forEach((tab) => {
            const isActive = tab.dataset.codeTab === id;
            tab.classList.toggle('is-active', isActive);
            tab.setAttribute('aria-selected', String(isActive));
            tab.setAttribute('tabindex', isActive ? '0' : '-1');
          });

          artifact.querySelectorAll('[data-code-panel]').forEach((panel) => {
            panel.hidden = panel.dataset.codePanel !== id;
          });
        };

        const copyText = async (text) => {
          if (navigator.clipboard?.writeText) {
            await navigator.clipboard.writeText(text);
            return;
          }

          const textarea = document.createElement('textarea');
          textarea.value = text;
          textarea.setAttribute('readonly', '');
          textarea.style.position = 'fixed';
          textarea.style.opacity = '0';
          document.body.appendChild(textarea);
          textarea.select();
          document.execCommand('copy');
          textarea.remove();
        };

        const copyArtifact = async (button) => {
          const artifact = button.closest('[data-code-artifact]');
          if (!artifact) return;
          const panel = artifact.querySelector('[data-code-panel]:not([hidden])');
          const text = panel?.textContent?.trim();
          if (!text) return;

          await copyText(text);
          button.dataset.copyState = 'copied';
          const label = button.querySelector('.xo-copy-label');
          if (label) {
            button.dataset.copyLabel ||= label.textContent?.trim() || 'Copier';
            label.textContent = button.dataset.copyDone || 'Copié';
          }
          window.setTimeout(() => {
            delete button.dataset.copyState;
            if (label) label.textContent = button.dataset.copyLabel || 'Copier';
          }, 1800);
        };

        document.querySelectorAll('[data-code-artifact]').forEach((artifact) => {
          const active = artifact.querySelector('[data-code-tab][aria-selected="true"]')
            || artifact.querySelector('[data-code-tab]');
          if (active instanceof HTMLElement && active.dataset.codeTab) {
            setCodePanel(artifact, active.dataset.codeTab);
          }
        });

        const explicitTheme = storedTheme();
        if (explicitTheme) setTheme(explicitTheme, false);
        else syncThemeButtons();

        lightQuery.addEventListener?.('change', () => {
          if (!storedTheme()) syncThemeButtons();
        });

        return { currentTheme, setTheme, setCodePanel, copyArtifact };
      })();

      window.trackSiteEvent = (name, props = {}) => {
        if (!name) return;
        if (typeof window.va === 'function') window.va('event', name, props);
      };

      document.addEventListener('click', (event) => {
        const themeToggle = event.target instanceof Element ? event.target.closest('[data-theme-toggle]') : null;
        if (themeToggle) {
          const nextTheme = ecosystemRuntime.currentTheme() === 'dark' ? 'light' : 'dark';
          ecosystemRuntime.setTheme(nextTheme);
          return;
        }

        const codeTab = event.target instanceof Element ? event.target.closest('[data-code-tab]') : null;
        if (codeTab) {
          const artifact = codeTab.closest('[data-code-artifact]');
          if (artifact && codeTab.dataset.codeTab) ecosystemRuntime.setCodePanel(artifact, codeTab.dataset.codeTab);
          return;
        }

        const copyButton = event.target instanceof Element ? event.target.closest('[data-copy-current]') : null;
        if (copyButton) {
          ecosystemRuntime.copyArtifact(copyButton);
          return;
        }

        const target = event.target instanceof Element ? event.target.closest('[data-event]') : null;
        if (!target) return;
        window.trackSiteEvent(target.dataset.event, {
          href: target.getAttribute('href') || undefined,
          label: target.textContent?.trim() || undefined,
        });
      });

      window.addEventListener('site:event', (event) => {
        window.trackSiteEvent(event.detail?.name, event.detail?.props || {});
      });
    </script>
  </body>
</html>
