---
import '@fontsource-variable/archivo/wdth.css';
import '@fontsource-variable/jetbrains-mono';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import '../styles/global.css';
import '../styles/x-operational-system.css';
import Header from '../components/Header.astro';
import { PARANOIA_CONTACT_EMAIL } from '../lib/contact';

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  image?: string;
  ogImage?: string;
  twitterImage?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  headerCtaHref?: string;
  headerCtaLabel?: string;
}

const DEFAULT_OG_IMAGE = '/social/linkedin-share.png';
const DEFAULT_TWITTER_IMAGE = '/social/x-card.png';

const {
  title,
  description = "Paranoia aide les équipes à détecter, masquer et relire les données sensibles dans leurs prompts avant d'utiliser des assistants IA.",
  canonicalPath = Astro.url.pathname,
  image,
  ogImage,
  twitterImage,
  ogImageWidth = 1200,
  ogImageHeight,
  headerCtaHref = '/#cta',
  headerCtaLabel = 'Beta',
} = Astro.props;

const canonicalUrl = new URL(canonicalPath, 'https://paranoia.re').toString();
const resolvedOgImage = ogImage ?? image ?? DEFAULT_OG_IMAGE;
const resolvedTwitterImage = twitterImage ?? image ?? DEFAULT_TWITTER_IMAGE;
const resolvedOgImageHeight = ogImageHeight ?? (resolvedOgImage === DEFAULT_OG_IMAGE ? 627 : 630);
const ogImageUrl = new URL(resolvedOgImage, 'https://paranoia.re').toString();
const twitterImageUrl = new URL(resolvedTwitterImage, 'https://paranoia.re').toString();

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      name: 'Paranoia',
      applicationCategory: 'SecurityApplication',
      operatingSystem: 'Web',
      url: 'https://paranoia.re',
      description:
        "Paranoia aide les équipes à détecter, masquer et relire les données sensibles dans leurs prompts avant d'utiliser des assistants IA.",
      inLanguage: 'fr',
      publisher: { '@id': 'https://paranoia.re/#org' },
    },
    {
      '@type': 'Organization',
      '@id': 'https://paranoia.re/#org',
      name: 'Paranoia',
      url: 'https://paranoia.re',
      sameAs: ['https://julientalbot.com', 'https://ergonomia.re'],
    },
  ],
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- General Sans (Fontshare CDN) — preferred display font, sharp display proportions. -->
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link rel="preconnect" href="https://cdn.fontshare.com" crossorigin />
    <link rel="stylesheet" href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600,700&display=swap" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="color-scheme" content="dark light" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.png" type="image/png" sizes="512x512" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content={ogImageWidth} />
    <meta property="og:image:height" content={resolvedOgImageHeight} />
    <meta property="og:image:alt" content="Paranoia - Réduire l'exposition des prompts IA" />
    <meta property="og:site_name" content="Paranoia" />
    <meta property="og:locale" content="fr_FR" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={twitterImageUrl} />
    <meta name="twitter:image:alt" content="Paranoia - Réduire l'exposition des prompts IA" />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body class="xds-theme xo-page xo-page--product">
    <a class="xo-skip-link" href="#main">Aller au contenu</a>
    <div class="app-shell">
      <Header ctaHref={headerCtaHref} ctaLabel={headerCtaLabel} />
      <slot />
      <footer class="xo-trust-footer product-footer">
        <div class="xo-shell xo-trust-grid">
          <div>
            <p class="xo-footer-brand">Paranoia</p>
            <p>Produit beta pour réduire l'exposition de données sensibles dans les prompts IA. Les limites et incidents restent documentés publiquement.</p>
          </div>
          <nav aria-label="Produit">
            <h3>Produit</h3>
            <a href="/#workflow">Fonctionnement</a>
            <a href="/#limits">Limites</a>
            <a href="/#fit">Pour qui</a>
            <a href="/#cta">Rejoindre la beta</a>
          </nav>
          <nav aria-label="Confiance">
            <h3>Confiance</h3>
            <a href="/rapports-incidents">Rapports d'incidents</a>
            <a href={`mailto:${PARANOIA_CONTACT_EMAIL}`} data-event="contact_mail_click">Support beta</a>
          </nav>
          <nav aria-label="Docs">
            <h3>Docs</h3>
            <a href="/#flow">Workflow détaillé</a>
            <a href="/#fit">Cas d'usage</a>
          </nav>
          <nav aria-label="Écosystème">
            <h3>Écosystème</h3>
            <a href="https://julientalbot.com/">Julien Talbot</a>
            <a href="https://ergonomia.re/">Ergonomia</a>
          </nav>
          <nav aria-label="Légal">
            <h3>Légal</h3>
            <a href="https://julientalbot.com/contact/">Contact</a>
            <a href={`mailto:${PARANOIA_CONTACT_EMAIL}`} data-event="contact_mail_click">Email</a>
          </nav>
        </div>
      </footer>
    </div>
    <Analytics />
    <SpeedInsights />
    <script is:inline>
      window.trackSiteEvent = (name, props = {}) => {
        if (!name) return;
        if (typeof window.va === 'function') window.va('event', name, props);
      };

      document.addEventListener('click', (event) => {
        const target = event.target instanceof Element ? event.target.closest('[data-event]') : null;
        if (!target) return;
        window.trackSiteEvent(target.dataset.event, {
          href: target.getAttribute('href') || undefined,
          label: target.textContent?.trim() || undefined,
        });
      });

      window.addEventListener('site:event', (event) => {
        window.trackSiteEvent(event.detail?.name, event.detail?.props || {});
      });
    </script>
  </body>
</html>
