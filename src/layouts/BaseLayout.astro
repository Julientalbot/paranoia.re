---
import '../styles/fonts.css';
import geistLatin from '@fontsource-variable/geist/files/geist-latin-wght-normal.woff2';
import geistMonoLatin from '@fontsource-variable/geist-mono/files/geist-mono-latin-wght-normal.woff2';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import '../styles/global.css';
import '../styles/x-operational-system.css';
import Header from '../components/Header.astro';
import { PARANOIA_CONTACT_EMAIL, PARANOIA_CONTACT_HREF } from '../lib/contact';

interface Props {
  title: string;
  description?: string;
  lang?: 'fr' | 'en';
  canonicalPath?: string;
  image?: string;
  ogImage?: string;
  twitterImage?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  headerCtaHref?: string;
  headerCtaLabel?: string;
  noIndex?: boolean;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const DEFAULT_OG_IMAGE = '/social/linkedin-share.png';
const DEFAULT_TWITTER_IMAGE = '/social/x-card.png';

const {
  title,
  description = "Paranoia (paranoia.re) réduit l'exposition de données sensibles dans les prompts IA avant envoi à un assistant — pas un terme psychiatrique.",
  lang = 'fr',
  canonicalPath = Astro.url.pathname,
  image,
  ogImage,
  twitterImage,
  ogImageWidth = 1200,
  ogImageHeight,
  headerCtaHref = PARANOIA_CONTACT_HREF,
  headerCtaLabel,
  noIndex = false,
  structuredData = [],
} = Astro.props;

const isEnglish = lang === 'en';
const resolvedHeaderCtaLabel = headerCtaLabel ?? (isEnglish ? 'Request pilot access' : 'Demander un accès pilote');
const canonicalUrl = new URL(canonicalPath, 'https://paranoia.re').toString();
const resolvedOgImage = ogImage ?? image ?? DEFAULT_OG_IMAGE;
const resolvedTwitterImage = twitterImage ?? image ?? DEFAULT_TWITTER_IMAGE;
const resolvedOgImageHeight = ogImageHeight ?? (resolvedOgImage === DEFAULT_OG_IMAGE ? 627 : 630);
const ogImageUrl = new URL(resolvedOgImage, 'https://paranoia.re').toString();
const twitterImageUrl = new URL(resolvedTwitterImage, 'https://paranoia.re').toString();
const structuredDataItems = Array.isArray(structuredData) ? structuredData : [structuredData];
const normalizedPath = canonicalPath.replace(/\/$/, '') || '/';
const languageAlternates = normalizedPath === '/' || normalizedPath === '/en'
  ? [
      { lang: 'fr', href: 'https://paranoia.re/' },
      { lang: 'en', href: 'https://paranoia.re/en' },
      { lang: 'x-default', href: 'https://paranoia.re/' },
    ]
  : [];

const breadcrumbLabels: Record<string, string> = {
  '/': 'Paranoia',
  '/en': 'Paranoia English overview',
  '/pilote': 'Accès pilote',
  '/cas-usages': 'Cas d’usage',
  '/confidentialite-prompts-ia': 'Confidentialité prompts IA',
  '/securite': 'Sécurité',
  '/rapports-incidents': 'Transparence',
};

const breadcrumbItems = normalizedPath === '/'
  ? []
  : [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Paranoia',
        item: 'https://paranoia.re/',
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: breadcrumbLabels[normalizedPath] ?? title,
        item: canonicalUrl,
      },
    ];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': 'https://paranoia.re/#website',
      name: 'Paranoia',
      url: 'https://paranoia.re',
      inLanguage: ['fr-FR', 'en-US'],
      publisher: { '@id': 'https://paranoia.re/#org' },
    },
    {
      '@type': 'SoftwareApplication',
      '@id': 'https://paranoia.re/#software',
      name: 'Paranoia',
      applicationCategory: 'SecurityApplication',
      operatingSystem: 'Web',
      url: 'https://paranoia.re',
      description:
        "Paranoia (paranoia.re) est un produit de confidentialité des prompts IA. Réduit l'exposition de données sensibles avant envoi — pas un terme psychiatrique.",
      inLanguage: ['fr-FR', 'en-US'],
      isAccessibleForFree: false,
      featureList: [
        'Détection de champs sensibles dans un prompt avant envoi',
        'Masquage contrôlable de noms, emails, organisations et identifiants',
        'Relecture humaine obligatoire avant usage dans un assistant IA',
        'Documentation publique du périmètre et des rapports techniques',
      ],
      audience: {
        '@type': 'BusinessAudience',
        audienceType: 'Équipes manipulant des prompts IA en contexte sensible',
      },
      offers: {
        '@type': 'Offer',
        name: 'Accès pilote privé',
        url: 'https://paranoia.re/pilote',
        availability: 'https://schema.org/LimitedAvailability',
      },
      creator: { '@id': 'https://julientalbot.com/#julien-talbot' },
      publisher: { '@id': 'https://paranoia.re/#org' },
    },
    {
      '@type': 'WebPage',
      '@id': `${canonicalUrl}#webpage`,
      url: canonicalUrl,
      name: title,
      description,
      inLanguage: lang === 'en' ? 'en' : 'fr-FR',
      isPartOf: { '@id': 'https://paranoia.re/#website' },
      about: { '@id': 'https://paranoia.re/#software' },
    },
    {
      '@type': 'Organization',
      '@id': 'https://paranoia.re/#org',
      name: 'Paranoia',
      url: 'https://paranoia.re',
      founder: { '@id': 'https://julientalbot.com/#julien-talbot' },
      sameAs: ['https://julientalbot.com/', 'https://julientalbot.com/terms'],
    },
    {
      '@type': 'Person',
      '@id': 'https://julientalbot.com/#julien-talbot',
      name: 'Julien Talbot',
      url: 'https://julientalbot.com/',
      jobTitle: "Ergonome de l'activité",
    },
    ...(breadcrumbItems.length ? [{
      '@type': 'BreadcrumbList',
      '@id': `${canonicalUrl}#breadcrumb`,
      itemListElement: breadcrumbItems,
    }] : []),
    ...structuredDataItems,
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <script is:inline src="/js/theme-init.js"></script>

    <link rel="preload" href={geistLatin} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={geistMonoLatin} as="font" type="font/woff2" crossorigin />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="color-scheme" content="dark light" />
    {noIndex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <link rel="canonical" href={canonicalUrl} />
    )}
    {languageAlternates.map((link) => (
      <link rel="alternate" hreflang={link.lang} href={link.href} />
    ))}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.png" type="image/png" sizes="512x512" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content={ogImageWidth} />
    <meta property="og:image:height" content={resolvedOgImageHeight} />
    <meta property="og:image:alt" content="Paranoia - Réduire l'exposition avant l'envoi" />
    <meta property="og:site_name" content="Paranoia" />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'fr_FR'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={twitterImageUrl} />
    <meta name="twitter:image:alt" content="Paranoia - Réduire l'exposition avant l'envoi" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="xds-theme xo-page xo-page--product">
    <a class="xo-skip-link" href="#main">{lang === 'en' ? 'Skip to content' : 'Aller au contenu'}</a>
    <div class="app-shell">
      <Header ctaHref={headerCtaHref} ctaLabel={resolvedHeaderCtaLabel} lang={lang} />
      <slot />
      <footer class="xo-trust-footer product-footer">
        <div class="xo-shell xo-trust-grid">
          <div>
            <p class="xo-footer-brand">Paranoia</p>
            <p>{isEnglish ? 'Pilot product to inspect, mask, and review sensitive AI prompts before sending.' : 'Produit pilote pour inspecter, masquer et relire les prompts IA sensibles avant envoi.'}</p>
          </div>
          <nav aria-label={isEnglish ? 'Product' : 'Produit'}>
            <h3>{isEnglish ? 'Product' : 'Produit'}</h3>
            <a href={isEnglish ? '/en#concrete' : '/#concrete'}>{isEnglish ? 'How it works' : 'Fonctionnement'}</a>
            <a href="/pilote">{isEnglish ? 'Pilot access' : 'Accès pilote'}</a>
            <a href="/cas-usages">{isEnglish ? 'Use cases' : 'Cas d’usage'}</a>
            <a href="/confidentialite-prompts-ia">{isEnglish ? 'Prompt privacy' : 'Confidentialité prompts'}</a>
            <a href="/securite">{isEnglish ? 'Security' : 'Sécurité'}</a>
          </nav>
          <nav aria-label={isEnglish ? 'Transparency' : 'Transparence'}>
            <h3>{isEnglish ? 'Transparency' : 'Transparence'}</h3>
            <a href="/rapports-incidents">{isEnglish ? 'What is sent' : 'Ce qui est envoyé'}</a>
            <a href={PARANOIA_CONTACT_HREF} data-event="contact_mail_click">{isEnglish ? 'Pilot support' : 'Support pilote'}</a>
          </nav>
          <nav aria-label={isEnglish ? 'Links' : 'Liens'}>
            <h3>{isEnglish ? 'Links' : 'Liens'}</h3>
            <a href="https://julientalbot.com/">Julien Talbot</a>
          </nav>
        </div>
      </footer>
    </div>
    <Analytics />
    <SpeedInsights />
    <script is:inline src="/js/ecosystem-runtime.js" defer></script>
  </body>
</html>
